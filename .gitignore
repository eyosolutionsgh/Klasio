node_modules/
dist/
.next/
# Isolated build output for the e2e server (NEXT_DIST_DIR), so it cannot collide with a dev server.
.next-e2e/
coverage/
# Uploaded objects — school crests, student photos and documents. Tenant data written at runtime
# under a random key, so a seed run leaves a fresh untracked directory every time and no two
# machines ever agree. The provider mkdirs on write, so nothing needs the folder to exist.
apps/api/storage/
*.log
.env
.env.local
playwright-report/
test-results/
**/e2e/screenshots/
# Run recordings (E2E_VIDEO=1) — regenerated on demand, never reviewed as source.
**/e2e/videos/
.turbo/

*.tsbuildinfo
.DS_Store
_to_delete/
*.tar.gz

# The vendor licensing portal keeps its own env and database.
apps/vendor/.env

# Next generates next-env.d.ts on every build, and its import line names the build directory —
# which varies here on purpose: the e2e build uses NEXT_DIST_DIR=.next-e2e so it never shares a
# directory with a running dev server. Tracking it means whichever build ran last decides what a
# fresh checkout references, and `.next-e2e` was committed once already. Next rewrites it
# unprompted, so nothing is lost by leaving it out.
apps/web/next-env.d.ts
apps/vendor/next-env.d.ts
