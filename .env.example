# Owner connection: `prisma migrate deploy`, the seed, and the few genuinely tenant-less reads
# (sign-in, gateway webhooks). Policies do not apply to the owner.
DATABASE_URL=postgresql://eyo:eyo_dev@localhost:5432/eyo_sms
# Runtime connection for the API. MUST be a non-owner role without BYPASSRLS, or row-level
# security silently stops protecting anything and a query that lost its where clause returns
# every school's rows instead of none. docker compose creates this role for you at first boot
# (ops/db-init/01-app-role.sh); for a local checkout, once:
#   CREATE ROLE eyo_app LOGIN PASSWORD '...';
#   GRANT USAGE ON SCHEMA public TO eyo_app;
#   GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO eyo_app;
APP_DATABASE_URL=postgresql://eyo_app:eyo_app_dev@localhost:5432/eyo_sms
# docker compose only: the password it creates eyo_app with, and signs APP_DATABASE_URL with.
APP_DB_PASSWORD=
# Signs every school session — staff, guardian and student alike. REQUIRED in production: the
# API refuses to start without it, because the development fallback is public in this repository
# and anyone holding it can forge an owner token for any school.
JWT_SECRET=change-me-in-production
API_PORT=4000
# Signs EYO's own vendor-console sessions. Separate from JWT_SECRET on purpose: a leaked school
# secret must not be able to mint vendor authority. REQUIRED in production — the API refuses to
# start without it, because the development fallback is public in this repository.
PLATFORM_JWT_SECRET=dev-platform-secret-do-not-use-in-prod

NEXT_PUBLIC_API_URL=http://localhost:4000

# File storage for student photos, student documents and bank-deposit proofs.
# Set STORAGE_S3_BUCKET to use S3 (or MinIO via STORAGE_S3_ENDPOINT). With it unset the API
# writes to STORAGE_LOCAL_DIR instead, so dev and air-gapped standalone boxes need no bucket.
STORAGE_LOCAL_DIR=./storage
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=af-south-1
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# Queue backend (BullMQ) for payment webhook retries and status re-query.
REDIS_URL=redis://localhost:6379

# Encrypts every per-school secret at rest: payment-gateway credentials and social account
# access tokens. Both are entered through the app, never here. 32 bytes, hex (64 chars) or
# base64. Generate: openssl rand -hex 32
# Renamed from PAYMENTS_ENCRYPTION_KEY, which is still read for existing deployments. If you are
# migrating, keep the SAME value — a different key cannot decrypt what the old one stored.
APP_ENCRYPTION_KEY=
# Base URL guardians reach for public pay links and gateway return/callback URLs.
PUBLIC_BASE_URL=http://localhost:3000

# Bulk SMS — Nalo Solutions gateway. When these are unset the SmsService falls back
# to a console "mock" provider (dev/offline), so no credits are spent.
# The `clientapi/` path is the form Nalo currently documents and the one verified against this
# account. The older path without it still resolves and still delivers, so switching is safe
# either way — but only this one is checked, so prefer it.
NALO_SMS_ENDPOINT=https://sms.nalosolutions.com/smsbackend/clientapi/Resl_Nalo/send-message/
NALO_SMS_USERNAME=
NALO_SMS_PASSWORD=
# The registered sender ID messages appear from. Nalo rejects unregistered IDs, and a school's
# own `smsSenderId` overrides this per send.
NALO_SMS_SOURCE=

# Transactional email — MailerSend. Carries school invitations, staff password resets and the
# guardian sign-in code for families with an email on file. Unset in development, where messages
# are logged instead; in production a missing token is refused rather than mocked, because an
# invitation that is silently never delivered has no other symptom.
MAILERSEND_API_TOKEN=
# Must be on a domain verified in the MailerSend account, or every send fails 422.
MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME=EYO School Management
# Optional. Where replies go; without it, replies bounce off the no-reply sender.
MAILERSEND_REPLY_TO=

# Escape hatches for a staging box that deliberately wants no delivery. Setting either to `true`
# in production accepts that messages are recorded as sent and reach nobody.
ALLOW_MOCK_SMS=false
ALLOW_MOCK_EMAIL=false

# Payment gateways are configured per school in the app, not here. With none connected the API
# uses a mock provider so development works; in production that is refused, because a mock would
# tell a parent a payment succeeded when nothing was charged. Set this only for a staging
# environment that deliberately wants fake payments.
ALLOW_MOCK_PAYMENTS=false

# The VENDOR's own gateway, for school subscription payments to EYO.
# Deliberately separate from the per-school gateway accounts configured in the app: those settle
# school fees to the school. Confusing the two would pay a school its own subscription money.
# Unset in development, where a mock stands in; in production a missing value is refused rather
# than mocked, because a mock would upgrade a school that never paid.
PLATFORM_GATEWAY=            # PAYSTACK | HUBTEL
PLATFORM_GATEWAY_SECRET=
PLATFORM_GATEWAY_PUBLIC_KEY=
PLATFORM_GATEWAY_MERCHANT=

# WhatsApp is REPLY-ONLY — the school can never open a conversation (see common/whatsapp-window.ts).
# The app secret verifies Meta's inbound callbacks. Without it the webhook fails closed, because
# a forged inbound message would force open the 24-hour reply window that rule depends on.
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=

