DATABASE_URL=postgresql://eyo:eyo_dev@localhost:5432/eyo_sms
JWT_SECRET=change-me-in-production
API_PORT=4000
# Signs EYO's own vendor-console sessions. Separate from JWT_SECRET on purpose: a leaked school
# secret must not be able to mint vendor authority. REQUIRED in production — the API refuses to
# start without it, because the development fallback is public in this repository.
PLATFORM_JWT_SECRET=dev-platform-secret-do-not-use-in-prod

NEXT_PUBLIC_API_URL=http://localhost:4000

# File storage for student photos, student documents and bank-deposit proofs.
# Set STORAGE_S3_BUCKET to use S3 (or MinIO via STORAGE_S3_ENDPOINT). With it unset the API
# writes to STORAGE_LOCAL_DIR instead, so dev and air-gapped standalone boxes need no bucket.
STORAGE_LOCAL_DIR=./storage
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=af-south-1
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# Queue backend (BullMQ) for payment webhook retries and status re-query.
REDIS_URL=redis://localhost:6379

# Payments. Gateway credentials are stored per school (encrypted) via the Gateway settings
# screen — not here. This key encrypts them at rest: 32 bytes, hex (64 chars) or base64.
# Generate: openssl rand -hex 32
PAYMENTS_ENCRYPTION_KEY=
# Base URL guardians reach for public pay links and gateway return/callback URLs.
PUBLIC_BASE_URL=http://localhost:3000

# Bulk SMS — Nalo Solutions gateway. When these are unset the SmsService falls back
# to a console "mock" provider (dev/offline), so no credits are spent.
NALO_SMS_ENDPOINT=https://sms.nalosolutions.com/smsbackend/Resl_Nalo/send-message/
NALO_SMS_USERNAME=
NALO_SMS_PASSWORD=
NALO_SMS_SOURCE=

# Owner connection: migrations, seed. Policies do not apply to the owner.
DATABASE_URL="postgresql://eyo:eyo@localhost:5432/eyo_sms"
# Runtime connection for the API. MUST be a non-owner role without BYPASSRLS, or row-level
# security silently stops protecting anything. Create it once:
#   CREATE ROLE eyo_app LOGIN PASSWORD '...';
#   GRANT USAGE ON SCHEMA public TO eyo_app;
#   GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO eyo_app;
APP_DATABASE_URL="postgresql://eyo_app:...@localhost:5432/eyo_sms"

# Payment gateways are configured per school in the app, not here. With none connected the API
# uses a mock provider so development works; in production that is refused, because a mock would
# tell a parent a payment succeeded when nothing was charged. Set this only for a staging
# environment that deliberately wants fake payments.
ALLOW_MOCK_PAYMENTS=false

# The VENDOR's own gateway, for school subscription payments to EYO.
# Deliberately separate from the per-school gateway accounts configured in the app: those settle
# school fees to the school. Confusing the two would pay a school its own subscription money.
# Unset in development, where a mock stands in; in production a missing value is refused rather
# than mocked, because a mock would upgrade a school that never paid.
PLATFORM_GATEWAY=            # PAYSTACK | HUBTEL
PLATFORM_GATEWAY_SECRET=
PLATFORM_GATEWAY_PUBLIC_KEY=
PLATFORM_GATEWAY_MERCHANT=

# WhatsApp is REPLY-ONLY — the school can never open a conversation (see common/whatsapp-window.ts).
# The app secret verifies Meta's inbound callbacks. Without it the webhook fails closed, because
# a forged inbound message would force open the 24-hour reply window that rule depends on.
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=

