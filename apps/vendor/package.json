{
  "name": "@eyo/vendor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "next build",
    "start": "next start -p 3200",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "seed": "ts-node --transpile-only --project prisma/tsconfig.json prisma/seed.ts",
    "db:seed:e2e": "ts-node --transpile-only --project prisma/tsconfig.json prisma/seed-e2e.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@eyo/shared": "workspace:*",
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^2.4.3",
    "next": "16.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.2",
    "prisma": "^6.16.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "tailwindcss": "^4.1.14",
    "@tailwindcss/postcss": "^4.1.14",
    "postcss": "^8.5.6",
    "@playwright/test": "^1.49.1",
    "@types/qrcode": "^1.5.6"
  }
}
