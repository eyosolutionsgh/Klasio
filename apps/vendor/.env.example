# The vendor's own database. Never a school's.
VENDOR_DATABASE_URL="postgresql://eyo:password@localhost:5432/eyo_vendor"

# Signs vendor staff sessions. REQUIRED in production.
VENDOR_SESSION_SECRET=

# The Ed25519 private key licences are signed with — the most sensitive value in the product.
# Either the PEM inline (or base64 of it), or a path to it.
# Generate once with: pnpm --filter @eyo/api licence:new-key
#
# Leave both blank in development and the portal signs with the committed key at
# ops/licence/dev-signing-key.pem, so a fresh clone can issue a licence immediately. Those licences
# verify only on a school also running from a checkout.
#
# In production the fallback is refused outright — that private half is in the repository. A
# deployed portal with neither variable set tracks licences and cannot issue them, which is also a
# reasonable way to run a read-only replica.
VENDOR_SIGNING_KEY=
VENDOR_SIGNING_KEY_PATH=

# Encrypts staff authenticator secrets at rest. REQUIRED in production (32 bytes, hex or base64).
# Unset in development falls back to a fixed key, so a fresh checkout can be signed into.
#   openssl rand -hex 32
VENDOR_ENCRYPTION_KEY=

# Emailed sign-in codes. Without these the portal offers the authenticator app and recovery codes
# only, and does not dangle an email option that would fail on click.
MAILERSEND_API_TOKEN=
MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME=
# Development only: accept that "sent" means "printed to the server console".
ALLOW_MOCK_EMAIL=

# First staff account, created by `pnpm --filter @eyo/vendor seed`.
VENDOR_ADMIN_EMAIL=
VENDOR_ADMIN_PASSWORD=
VENDOR_ADMIN_NAME=
# The bootstrap account's authenticator secret. Second factors are required, so the seed enrols it
# rather than leaving an account nobody can finish signing into. Set this to something only you
# hold, or scan the key the seed prints and then re-enrol.
VENDOR_ADMIN_TOTP_SECRET=
