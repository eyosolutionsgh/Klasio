// EYO SMS — core schema (Phase 1: SIS, attendance, assessment, fees)
// Rules: every tenant-owned table carries schoolId; the fee ledger is append-only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenancy, users, platform ─────────────────────────────────────────

enum Tier {
  BASIC
  MEDIUM
  ADVANCED
}

/// Terminal-report layout. GES is the statutory-looking default; MODERN is a cleaner
/// alternative some private schools prefer (docs/02 §2.3).
enum ReportTemplate {
  GES
  MODERN
}

enum Role {
  OWNER
  HEAD
  BURSAR
  TEACHER
  FRONT_DESK
  GUARDIAN
  /// Students authenticate through their own portal (admission number + PIN), not the staff
  /// login; the role exists so RBAC can name them (docs/02 §2.10).
  STUDENT
}

model School {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  motto     String?
  address   String?
  phone     String?
  email     String?
  region    String?
  country   String   @default("GH")
  website   String?
  currency  String   @default("GHS")
  tier      Tier     @default(BASIC)
  /// Storage key for the school crest. Bytes are served by GET /school/logo, never a public URL.
  logoUrl   String?
  /// Hex brand colour applied to primary surfaces (sidebar, top bar, primary buttons).
  brandColor String? @db.VarChar(7)
  smsSenderId String? // registered SMS sender ID (e.g. "BRIGHTON")
  smsCredits  Int      @default(0) // pay-as-you-go SMS units the school has bought
  reportTemplate ReportTemplate @default(GES)
  /// How the two halves of a subject mark are weighted. GES convention is 30/70, but schools
  /// differ and early years often run 100/0.
  sbaWeight  Int @default(30)
  examWeight Int @default(70)
  /// How this school numbers its students, e.g. `BA-{YYYY}-{####}`.
  ///
  /// Every school already has a house style, printed on report cards, ID cards and the register.
  /// Imposing ours would mean two numbers for every child. See common/admission-no.ts.
  admissionNoFormat String @default("{YYYY}-{####}")
  /// The next number in the school's own run. Held here rather than counted from the students
  /// table so that withdrawing a child never causes the next enrolment to reuse their number.
  admissionNoNext   Int    @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  academicYears AcademicYear[]
  levels        Level[]
  classes       ClassRoom[]
  subjects      Subject[]
  students      Student[]
  guardians     Guardian[]

  subscription  Subscription?
  staffRoles    StaffRole[]
}

model User {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  /// Legacy coarse role. Retained because it still identifies the proprietor (OWNER always holds
  /// every permission) and because guardians and students are principals of a different kind.
  /// Day-to-day authority now comes from `staffRole`.
  role         Role
  /// The school-defined role this person holds. Null only for the proprietor and for non-staff
  /// principals, who do not take their authority from a role row.
  staffRoleId  String?
  staffRole    StaffRole? @relation(fields: [staffRoleId], references: [id], onDelete: SetNull)
  /// Permissions granted or revoked for this one person, on top of their role.
  ///
  /// Deliberately narrow: a school with one teacher who also covers the gate should not need a
  /// whole new role. Revocations win over grants, so taking something away is always decisive.
  extraPermissions   String[] @default([])
  revokedPermissions String[] @default([])
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])

  timetableSlots TimetableSlot[]
}

/// A named bundle of permissions, owned and editable by the school.
///
/// Seeded from the presets in common/permissions.ts, which follow how private schools actually
/// staff — head, assistant head, head of department, class and subject teacher, exams officer,
/// bursar, accounts clerk, registrar, front desk, nurse, librarian, IT administrator. A school
/// may rename, re-scope or delete any of them, or invent its own.
model StaffRole {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  description String?
  /// Permission codes, validated against the registry on write so a renamed permission cannot be
  /// resurrected by an old row.
  permissions String[] @default([])
  /// Stable key of the preset this came from; null for a school's own invention. Marks
  /// provenance only — presets are fully editable.
  presetKey   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  detail    Json?
  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
}

// ── Academic structure ───────────────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  terms     Term[]

  @@unique([schoolId, name])
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  name           String
  startDate      DateTime
  endDate        DateTime
  nextTermBegins DateTime?
  isCurrent      Boolean      @default(false)

  @@unique([academicYearId, name])
}

enum LevelCategory {
  PRE_SCHOOL
  PRIMARY
  JHS
  SHS
}

model Level {
  id              String         @id @default(cuid())
  schoolId        String
  school          School         @relation(fields: [schoolId], references: [id])
  name            String
  category        LevelCategory
  /// Short code for the admission-number format, e.g. PRI or JHS. Optional.
  code            String?
  order           Int
  gradingSchemeId String? // which grading scheme this level's reports use (per-level selection)
  gradingScheme   GradingScheme? @relation(fields: [gradingSchemeId], references: [id])
  classes         ClassRoom[]
  components      AssessmentComponent[]

  @@unique([schoolId, name])

  applicants           Applicant[]
  customFields         CustomFieldDef[]
  documentRequirements DocumentRequirement[]
  calendarEvents       CalendarEvent[]
  learningResources    LearningResource[]
  concessionRules ConcessionRule[]
}

model ClassRoom {
  id            String    @id @default(cuid())
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id])
  levelId       String
  level         Level     @relation(fields: [levelId], references: [id])
  name          String
  classTeacherId String?
  students      Student[]

  @@unique([schoolId, name])

  learningResources LearningResource[]
  timetableSlots    TimetableSlot[]
}

model Subject {
  id       String  @id @default(cuid())
  schoolId String
  school   School  @relation(fields: [schoolId], references: [id])
  name     String
  code     String
  isCore   Boolean @default(false)

  components AssessmentComponent[]

  @@unique([schoolId, code])

  learningResources LearningResource[]
  timetableSlots    TimetableSlot[]
}

// ── Students & guardians ─────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  TRANSFERRED
  WITHDRAWN
  GRADUATED
}

enum Gender {
  MALE
  FEMALE
}

model Student {
  id           String        @id @default(cuid())
  schoolId     String
  school       School        @relation(fields: [schoolId], references: [id])
  admissionNo  String
  firstName    String
  lastName     String
  otherNames   String?
  gender       Gender
  dateOfBirth  DateTime
  photoUrl     String?
  classId      String?
  classRoom    ClassRoom?    @relation(fields: [classId], references: [id])
  status       StudentStatus @default(ACTIVE)
  enrolledAt   DateTime      @default(now())
  exitDate     DateTime? // set on transfer / withdrawal / graduation
  exitReason   String?
  medicalNotes String?
  /// Hash of the portal PIN the school issues. Null until a PIN is set; students without one
  /// simply cannot sign in, which is the right default for the youngest classes.
  portalPinHash String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  guardians    StudentGuardian[]
  attendance   AttendanceRecord[]
  scores       Score[]
  termReports  TermReport[]
  invoices     Invoice[]
  ledger       LedgerEntry[]
  documents      StudentDocument[]
  bankDeposits   BankDeposit[]
  paymentIntents PaymentIntent[]
  feeItems       StudentFeeItem[]
  pickupDelegates PickupDelegate[]
  releases        ReleaseLog[]
  dismissalRequests DismissalRequest[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId, classId])

  installments      Installment[]
  fieldValues       StudentFieldValue[]
  concessionAwards ConcessionAward[]
}

/// Files attached to a student (birth certificate, immunisation card, previous report…).
/// `key` addresses the object in storage; bytes are never stored in the database.
model StudentDocument {
  id           String   @id @default(cuid())
  schoolId     String
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  kind         String   @default("OTHER")
  filename     String
  contentType  String
  size         Int
  key          String
  uploadedById String
  createdAt    DateTime @default(now())

  @@index([schoolId, studentId])
}

enum DepositStatus {
  PENDING
  CONFIRMED
  REJECTED
}

/// A bank deposit claimed by a guardian/office with proof attached. Nothing reaches the
/// ledger until a bursar confirms it — confirmation appends a PAYMENT entry + receipt.
model BankDeposit {
  id            String        @id @default(cuid())
  schoolId      String
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])
  termId        String?
  amount        Decimal       @db.Decimal(12, 2)
  bankName      String?
  bankRef       String?
  depositedAt   DateTime
  proofKey      String?
  status        DepositStatus @default(PENDING)
  /// Reference of the ledger entry created on confirmation — also the idempotency key.
  reference     String        @unique
  note          String?
  reviewNote    String?
  submittedById String
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())

  @@index([schoolId, status])
}

enum CustodyFlag {
  NONE
  RESTRICTED
  BLOCKED
}

model Guardian {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  firstName     String
  lastName      String
  phone         String
  email         String?
  whatsappOptIn Boolean  @default(false)
  createdAt     DateTime @default(now())

  students StudentGuardian[]
  otps     GuardianOtp[]
  pickupCredential PickupCredential?
  dismissalRequests DismissalRequest[]

  @@index([schoolId, phone])

  /// Storage key for a face photo, shown to gate staff at handoff. Bytes are served through the
  /// API, never a public URL — this is a picture of a person attached to a named child.
  photoUrl String?

  whatsappConversations WhatsAppConversation[]
}

/// One-time sign-in codes for the guardian portal. Only a hash of the code is stored, so a
/// database leak cannot be replayed into guardian accounts.
model GuardianOtp {
  id         String    @id @default(cuid())
  schoolId   String
  guardianId String
  guardian   Guardian  @relation(fields: [guardianId], references: [id])
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([guardianId])
}

model StudentGuardian {
  studentId    String
  student      Student     @relation(fields: [studentId], references: [id])
  guardianId   String
  guardian     Guardian    @relation(fields: [guardianId], references: [id])
  relationship String
  isPrimary    Boolean     @default(false)
  canPickup    Boolean     @default(true)
  custodyFlag  CustodyFlag @default(NONE)

  @@id([studentId, guardianId])
}

// ── Attendance ───────────────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  schoolId   String
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id])
  classId    String
  termId     String
  date       DateTime         @db.Date
  status     AttendanceStatus
  markedById String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, date])
  @@index([schoolId, classId, date])
}

// ── Assessment & terminal reports ────────────────────────────────────

enum GradingKind {
  GES_CLASSIC
  NACCA_BANDS
  EARLY_YEARS
}

model GradingScheme {
  id       String      @id @default(cuid())
  schoolId String
  name     String
  kind     GradingKind
  /// bands: [{ min, max, grade, remark }] — for NaCCA/early-years, `grade` carries the proficiency label
  bands    Json
  levels   Level[]

  @@unique([schoolId, name])
}

/// Continuous assessment counts toward the SBA portion; exams toward the exam portion. A
/// subject may have any number of each — three class tests and two papers is as valid as one
/// of each.
enum AssessmentCategory {
  CONTINUOUS
  EXAM
}

/// One markable item: a class test, an assignment, a project, an end-of-term paper.
///
/// Scope narrows from the school down: a component with no subject and no level applies
/// everywhere, one with a subject applies to that subject in every class, one with both applies
/// only there. That is what lets JHS 2 Science have a practical that no other subject has,
/// without forcing every class to carry the same four columns.
model AssessmentComponent {
  id        String             @id @default(cuid())
  schoolId  String
  name      String
  maxScore  Int
  category  AssessmentCategory @default(CONTINUOUS)
  /// Null means every subject.
  subjectId String?
  subject   Subject?           @relation(fields: [subjectId], references: [id])
  /// Null means every level.
  levelId   String?
  level     Level?             @relation(fields: [levelId], references: [id])
  order     Int                @default(0)
  createdAt DateTime           @default(now())

  scores Score[]

  @@index([schoolId, subjectId, levelId])
}

model Score {
  id          String              @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student             @relation(fields: [studentId], references: [id])
  subjectId   String
  termId      String
  componentId String
  component   AssessmentComponent @relation(fields: [componentId], references: [id])
  rawScore    Float
  enteredById String
  updatedAt   DateTime            @updatedAt

  @@unique([studentId, subjectId, termId, componentId])
  @@index([schoolId, termId, subjectId])
}

model TermReport {
  id                String    @id @default(cuid())
  schoolId          String
  studentId         String
  student           Student   @relation(fields: [studentId], references: [id])
  termId            String
  classId           String
  /// lines: [{ subject, sba30, exam70, total, grade, remark, position }]
  lines             Json
  overallTotal      Float
  classPosition     Int?
  classSize         Int?
  attendancePresent Int       @default(0)
  attendanceTotal   Int       @default(0)
  conduct           String?
  interest          String?
  teacherRemark     String?
  headRemark        String?
  publishedAt       DateTime?
  generatedAt       DateTime  @default(now())

  @@unique([studentId, termId])
  @@index([schoolId, termId, classId])
}

// ── Fees: append-only ledger ─────────────────────────────────────────

model FeeItem {
  id       String  @id @default(cuid())
  schoolId String
  termId   String
  levelId  String?
  name     String
  amount   Decimal @db.Decimal(12, 2)
  /// Optional items (transport, feeding) are billed only to the students subscribed to them.
  optional Boolean @default(false)

  subscriptions StudentFeeItem[]

  @@index([schoolId, termId])
}

/// Which students have taken up an optional fee item this term. Compulsory items need no such
/// row — everyone gets them.
model StudentFeeItem {
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  feeItemId String
  feeItem   FeeItem  @relation(fields: [feeItemId], references: [id], onDelete: Cascade)
  schoolId  String
  createdAt DateTime @default(now())

  @@id([studentId, feeItemId])
  @@index([schoolId])
}

model Invoice {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  termId    String
  number    String
  /// lines: [{ name, amount }]
  lines     Json
  total     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  paymentIntents PaymentIntent[]

  @@unique([schoolId, number])
  @@unique([studentId, termId])
  @@index([schoolId, termId])

  installments Installment[]
}

enum LedgerType {
  INVOICE
  PAYMENT
  DISCOUNT
  WAIVER
  REVERSAL
}

enum PaymentMethod {
  CASH
  BANK
  MOMO
  CARD
}

/// Append-only. Never updated, never deleted. Corrections are REVERSAL entries.
model LedgerEntry {
  id          String         @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student        @relation(fields: [studentId], references: [id])
  termId      String?
  type        LedgerType
  /// Positive amounts. INVOICE increases balance owed; PAYMENT/DISCOUNT/WAIVER decrease it;
  /// REVERSAL negates the entry it references (reversedId).
  amount      Decimal        @db.Decimal(12, 2)
  method      PaymentMethod?
  reference   String         @unique
  reversedId  String?
  note        String?
  createdById String
  createdAt   DateTime       @default(now())

  receipt Receipt?

  @@index([schoolId, studentId])
  @@index([schoolId, createdAt])
}

/// Per-school counters for human-facing document numbers (receipts, payments, invoices).
///
/// These were each derived from `count(rows) + 1`, which is not a counter: two clerks taking
/// money at the same moment both read the same total and both claim the same receipt number.
/// One insert then loses the unique index — and because the whole request runs in one
/// transaction, the loser's ledger entry is discarded with it. Held here and incremented
/// atomically, the way `School.admissionNoNext` already is.
model NumberSequence {
  id       String @id @default(cuid())
  schoolId String
  /// RECEIPT | PAYMENT | INVOICE
  name     String
  next     Int    @default(1)

  @@unique([schoolId, name])
}

model Receipt {
  id            String      @id @default(cuid())
  schoolId      String
  ledgerEntryId String      @unique
  ledgerEntry   LedgerEntry @relation(fields: [ledgerEntryId], references: [id])
  number        String
  issuedAt      DateTime    @default(now())

  @@unique([schoolId, number])
}

// ── Online payments (Medium: fees.online) ────────────────────────────

enum GatewayProvider {
  HUBTEL
  PAYSTACK
  MOCK
}

enum GatewayMode {
  TEST
  LIVE
}

enum PaymentChannel {
  MOMO
  CARD
  USSD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

/// Per-school merchant credentials. `secretEnc` is AES-256-GCM ciphertext (common/crypto.ts);
/// plaintext secrets are never stored or returned by the API.
model GatewayAccount {
  id             String          @id @default(cuid())
  schoolId       String
  provider       GatewayProvider
  mode           GatewayMode     @default(TEST)
  publicKey      String?
  secretEnc      String
  merchantNumber String? // Hubtel merchant account number
  subaccountCode String? // Paystack subaccount, if split settlement is used
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([schoolId, provider])
}

/// One attempt to collect money. Only a SUCCESS ever writes to the ledger, and it does so
/// with `reference` — LedgerEntry.reference is unique, which makes application idempotent.
model PaymentIntent {
  id          String          @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id])
  invoiceId   String?
  invoice     Invoice?        @relation(fields: [invoiceId], references: [id])
  termId      String?
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("GHS")
  reference   String          @unique
  provider    GatewayProvider
  channel     PaymentChannel
  status      PaymentStatus   @default(PENDING)
  providerRef String?
  checkoutUrl String?
  /// Opaque token for the public (unauthenticated) pay link shared with guardians.
  payToken    String?         @unique
  payerPhone  String?
  failureCode String?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([schoolId, status])
  @@index([schoolId, createdAt])
}

/// Raw gateway callbacks. `providerEventId` is unique so a replayed webhook is a no-op.
model WebhookEvent {
  id              String          @id @default(cuid())
  provider        GatewayProvider
  providerEventId String
  schoolId        String?
  reference       String?
  verified        Boolean         @default(false)
  payload         Json
  error           String?
  receivedAt      DateTime        @default(now())
  processedAt     DateTime?

  @@unique([provider, providerEventId])
  @@index([reference])
}

// ── Communication ────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  schoolId    String
  title       String
  body        String
  audience    String    @default("ALL")
  createdById String
  publishedAt DateTime  @default(now())

  @@index([schoolId, publishedAt])
}

enum SmsStatus {
  QUEUED
  SENT
  FAILED
}

/// Outbound bulk-SMS log. One row per recipient; `cost` debits School.smsCredits.
model SmsMessage {
  id          String    @id @default(cuid())
  schoolId    String
  to          String
  body        String
  status      SmsStatus @default(QUEUED)
  provider    String    @default("mock")
  providerRef String?
  cost        Int       @default(1)
  batchId     String?
  error       String?
  createdById String
  createdAt   DateTime  @default(now())

  @@index([schoolId, createdAt])
  @@index([schoolId, batchId])
}

// ── Pickup & drop-off safety (docs/02 §2.5) ──────────────────────────

/// Someone other than a guardian who may collect a child — a driver, an aunt, a neighbour.
/// Time-limited by default, because "just this term" is how these arrangements actually work.
model PickupDelegate {
  id           String    @id @default(cuid())
  schoolId     String
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id])
  name         String
  phone        String
  relationship String
  expiresAt    DateTime?
  active       Boolean   @default(true)
  createdById  String
  createdAt    DateTime  @default(now())

  credential PickupCredential?

  @@index([schoolId, studentId])
}

/// The credential a collector presents at the gate: a QR token on a printed card or a phone,
/// with a PIN as the fallback for guardians without a smartphone.
///
/// Only hashes of the PIN are stored, and the QR token is opaque random — a leaked database
/// must not let anyone walk out with a child.
model PickupCredential {
  id         String          @id @default(cuid())
  schoolId   String
  /// Exactly one of these is set.
  guardianId String?         @unique
  guardian   Guardian?       @relation(fields: [guardianId], references: [id])
  delegateId String?         @unique
  delegate   PickupDelegate? @relation(fields: [delegateId], references: [id], onDelete: Cascade)
  /// Looked up on scan; random and unguessable, rotated when a card is lost.
  token      String          @unique
  pinHash    String
  issuedAt   DateTime        @default(now())
  revokedAt  DateTime?

  @@index([schoolId])
}

/// How the collector was identified at the gate. Whether staff released *against advice* is a
/// separate fact, carried by overrideReason — conflating the two makes the log unreadable.
enum ReleaseMethod {
  QR
  PIN
  MANUAL
}

/// Immutable record of a child leaving: who, to whom, when, how, and who authorised it.
/// Never updated or deleted — this is the document you reach for when something goes wrong.
model ReleaseLog {
  id             String        @id @default(cuid())
  schoolId       String
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id])
  /// Name captured at the time: a delegate may later be removed, but the log must still read.
  collectedBy    String
  collectorKind  String
  collectorId    String?
  method         ReleaseMethod
  /// Set when staff released against the system's advice; carries their stated reason.
  overrideReason String?
  releasedById   String
  releasedAt     DateTime      @default(now())
  /// Idempotency key minted by the gate device before it tries to send.
  ///
  /// A release is an append, so replaying a queued one would record the same child leaving
  /// twice. This makes the write safe to retry: the second attempt finds the row and returns it
  /// instead of creating another. Without it the gate could not work offline at all.
  clientRef      String?

  @@unique([schoolId, clientRef])
  @@index([schoolId, releasedAt])
  @@index([studentId])
}

enum DismissalStatus {
  PENDING
  APPROVED
  DECLINED
}

/// A guardian telling the school, today, that the usual arrangement is changing.
model DismissalRequest {
  id          String          @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id])
  guardianId  String
  guardian    Guardian        @relation(fields: [guardianId], references: [id])
  forDate     DateTime
  details     String
  status      DismissalStatus @default(PENDING)
  decidedById String?
  decidedAt   DateTime?
  decisionNote String?
  createdAt   DateTime        @default(now())

  @@index([schoolId, forDate])
  @@index([studentId])
}

/// School-editable message bodies for automatic SMS. Placeholders in {braces} are substituted
/// at send time, so a school can reword a reminder without a deploy.
model MessageTemplate {
  id        String   @id @default(cuid())
  schoolId  String
  /// FEE_REMINDER_GENTLE, FEE_REMINDER_FIRM, ABSENCE_ALERT, RESULTS_READY, PICKUP_RELEASED
  kind      String
  body      String
  updatedAt DateTime @updatedAt

  @@unique([schoolId, kind])
}

/// A repeating automatic job a school has switched on (currently fee reminders). Kept in the
/// database rather than config so each school chooses its own day and hour.
model ScheduledJob {
  id         String    @id @default(cuid())
  schoolId   String
  kind       String
  enabled    Boolean   @default(false)
  /// 0-6, Sunday = 0. Null means every weekday.
  dayOfWeek  Int?
  hour       Int       @default(9)
  lastRunAt  DateTime?
  updatedAt  DateTime  @updatedAt

  @@unique([schoolId, kind])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2 — money, safety and reach
// ─────────────────────────────────────────────────────────────────────────────

/// One scheduled part-payment of an invoice.
///
/// The ledger stays the single source of what is owed; an installment is a *promise* about when
/// a slice of it falls due, never a second record of the money. Nothing here is summed to build
/// a balance — that always comes from LedgerEntry.
model Installment {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  termId    String?
  sequence  Int
  amount    Decimal  @db.Decimal(12, 2)
  dueDate   DateTime
  note      String?
  createdAt DateTime @default(now())

  @@unique([invoiceId, sequence])
  @@index([schoolId, dueDate])
  @@index([schoolId, studentId])
}

enum SettlementStatus {
  UNMATCHED
  MATCHED
  /// Matched but the amounts differ beyond tolerance — a human must look.
  DISPUTED
  IGNORED
}

/// A settlement file from a gateway: what they say they actually paid the school.
model SettlementBatch {
  id           String   @id @default(cuid())
  schoolId     String
  provider     GatewayProvider
  filename     String
  /// Gross the school expected, net the gateway actually remitted after charges.
  grossTotal   Decimal  @db.Decimal(12, 2)
  netTotal     Decimal  @db.Decimal(12, 2)
  rowCount     Int
  matchedCount Int      @default(0)
  uploadedById String?
  createdAt    DateTime @default(now())

  rows SettlementRow[]

  @@index([schoolId, createdAt])
}

/// One line of a settlement file, matched against a PaymentIntent by reference.
model SettlementRow {
  id         String           @id @default(cuid())
  schoolId   String
  batchId    String
  batch      SettlementBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  reference  String
  gross      Decimal          @db.Decimal(12, 2)
  /// What the gateway actually remitted; gross minus their charge.
  net        Decimal          @db.Decimal(12, 2)
  paidAt     DateTime?
  status     SettlementStatus @default(UNMATCHED)
  intentId   String?
  /// Why this row is disputed or was ignored — always a human sentence, never a code.
  note       String?
  resolvedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([schoolId, status])
  @@index([schoolId, reference])
}

enum ApplicantStage {
  ENQUIRY
  APPLIED
  ASSESSED
  OFFERED
  ACCEPTED
  ENROLLED
  DECLINED
}

/// A child applying to the school, before they are a Student.
///
/// Deliberately a separate table: an applicant has no class, no ledger and no attendance, and
/// letting them into Student early would corrupt enrolment counts and the fee cap.
model Applicant {
  id           String         @id @default(cuid())
  schoolId     String
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  gender       Gender?
  levelId      String?
  level        Level?         @relation(fields: [levelId], references: [id])
  guardianName String
  guardianPhone String
  guardianEmail String?
  previousSchool String?
  notes        String?
  stage        ApplicantStage @default(APPLIED)
  /// Set when the applicant becomes a Student, so the pipeline keeps an honest history.
  studentId    String?
  reference    String
  decidedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([schoolId, reference])
  @@index([schoolId, stage])
}

enum CustomFieldKind {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  CHOICE
}

/// A school-defined extra field on a student record, optionally only for one level.
model CustomFieldDef {
  id        String          @id @default(cuid())
  schoolId  String
  label     String
  kind      CustomFieldKind @default(TEXT)
  /// CHOICE options; ignored for every other kind.
  options   Json?
  levelId   String?
  level     Level?          @relation(fields: [levelId], references: [id], onDelete: Cascade)
  required  Boolean         @default(false)
  order     Int             @default(0)
  createdAt DateTime        @default(now())

  values StudentFieldValue[]

  @@index([schoolId, levelId])
}

model StudentFieldValue {
  id        String         @id @default(cuid())
  schoolId  String
  studentId String
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fieldId   String
  field     CustomFieldDef @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value     String
  updatedAt DateTime       @updatedAt

  @@unique([studentId, fieldId])
  @@index([schoolId])
}

/// A document every child at a level is expected to have on file.
model DocumentRequirement {
  id        String   @id @default(cuid())
  schoolId  String
  label     String
  /// Matches StudentDocument.kind, which is how completion is worked out.
  kind      String
  levelId   String?
  level     Level?   @relation(fields: [levelId], references: [id], onDelete: Cascade)
  required  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([schoolId, levelId])
}

enum RemarkKind {
  TEACHER
  HEAD
  CONDUCT
  INTEREST
}

/// A reusable report-card comment, so a class teacher writing 40 reports is not starting cold.
model RemarkBank {
  id        String     @id @default(cuid())
  schoolId  String
  kind      RemarkKind
  text      String
  /// Roughly which band this suits, so the editor can offer sensible ones first. Null = any.
  minScore  Int?
  maxScore  Int?
  uses      Int        @default(0)
  createdAt DateTime   @default(now())

  @@index([schoolId, kind])
}

enum EventAudience {
  ALL
  STAFF
  GUARDIANS
  STUDENTS
}

model CalendarEvent {
  id          String        @id @default(cuid())
  schoolId    String
  title       String
  details     String?
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean       @default(true)
  location    String?
  audience    EventAudience @default(ALL)
  levelId     String?
  level       Level?        @relation(fields: [levelId], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([schoolId, startsAt])
}

/// A file a teacher shares with a class: notes, homework, past questions.
model LearningResource {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  description String?
  /// Storage key. Bytes are served through the API, never a public URL.
  key         String
  filename    String
  mimeType    String
  sizeBytes   Int
  subjectId   String?
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  levelId     String?
  level       Level?   @relation(fields: [levelId], references: [id], onDelete: SetNull)
  classId     String?
  classRoom   ClassRoom? @relation(fields: [classId], references: [id], onDelete: SetNull)
  /// Guardians and students only see it once the teacher publishes.
  published   Boolean  @default(false)
  uploadedById String?
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([schoolId, levelId])
  @@index([schoolId, classId])

  downloadLog ResourceDownload[]
}

/// Who opened a resource — the catalog asks for download tracking.
model ResourceDownload {
  id         String   @id @default(cuid())
  schoolId   String
  resourceId String
  resource   LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  /// Exactly one of these is set, depending on which portal did the download.
  userId     String?
  guardianId String?
  studentId  String?
  createdAt  DateTime @default(now())

  @@index([schoolId, resourceId])
}

/// A named slot in the school day — "Period 1", "Break". Shared by every class.
model TimetablePeriod {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  /// Minutes from midnight, so comparisons and clash detection are plain integer maths.
  startsMin Int
  endsMin   Int
  order     Int      @default(0)
  isBreak   Boolean  @default(false)
  createdAt DateTime @default(now())

  slots TimetableSlot[]

  @@index([schoolId, order])
}

/// One class, one period, one weekday: what is being taught and by whom.
model TimetableSlot {
  id        String          @id @default(cuid())
  schoolId  String
  classId   String
  classRoom ClassRoom       @relation(fields: [classId], references: [id], onDelete: Cascade)
  periodId  String
  period    TimetablePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  /// 1 = Monday … 5 = Friday. Ghanaian schools rarely timetable weekends.
  weekday   Int
  subjectId String?
  subject   Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacherId String?
  teacher   User?           @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  room      String?
  createdAt DateTime        @default(now())

  /// A class cannot be in two places in one period. Teacher clashes are checked in code,
  /// because they span classes and a unique index cannot express "unless the teacher is null".
  @@unique([classId, periodId, weekday])
  @@index([schoolId, teacherId, weekday])
}

enum WhatsAppDirection {
  INBOUND
  OUTBOUND
}

/// A WhatsApp thread with one phone number.
///
/// The school never opens one. `windowExpiresAt` is set only by an inbound message and is the
/// gate on every reply: outside it we cannot answer without a paid template, and this product
/// has decided not to send those. See WhatsAppMessage.
model WhatsAppConversation {
  id              String    @id @default(cuid())
  schoolId        String
  phone           String
  guardianId      String?
  guardian        Guardian? @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  /// 24 hours after the guardian's last inbound message. Null or past = we must stay silent.
  windowExpiresAt DateTime?
  lastInboundAt   DateTime?
  lastOutboundAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  messages WhatsAppMessage[]

  @@unique([schoolId, phone])
  @@index([schoolId, windowExpiresAt])
}

model WhatsAppMessage {
  id             String               @id @default(cuid())
  schoolId       String
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      WhatsAppDirection
  body           String
  /// Provider's own id, used to make webhook redelivery idempotent.
  externalId     String?
  sentById       String?
  createdAt      DateTime             @default(now())

  @@unique([schoolId, externalId])
  @@index([schoolId, conversationId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SaaS subscription billing
//
// The school is the *customer* here, not the payee. School fees settle to the school's own
// GatewayAccount; subscription payments settle to the vendor, through platform credentials held
// in env. Confusing the two would pay a school its own subscription money, so the two paths
// deliberately share no configuration.
// ─────────────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  /// Paid and inside its period.
  ACTIVE
  /// Period ended without renewal. The school keeps working — see the downgrade rule.
  PAST_DUE
  /// Will not renew; reverts to BASIC when the paid period ends.
  CANCELLING
  CANCELLED
}

model Subscription {
  id       String             @id @default(cuid())
  schoolId String             @unique
  school   School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  tier     Tier
  status   SubscriptionStatus @default(ACTIVE)
  /// What the school pays per term at signing, held so a later price change cannot silently
  /// re-bill an existing customer at a new rate.
  amount   Decimal            @db.Decimal(12, 2)
  currency String             @default("GHS")
  /// Enrolment the price was based on. Re-quoted each renewal, never mid-period.
  studentCount Int
  periodStart DateTime
  periodEnd   DateTime
  /// Set when the school asks to move down; applied at periodEnd, never immediately.
  pendingTier Tier?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  invoices SubscriptionInvoice[]

  @@index([status, periodEnd])
}

enum SubscriptionInvoiceStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

/// One term's subscription charge. Separate from the school's own fee Invoice, which bills
/// parents — these two must never be summed together.
model SubscriptionInvoice {
  id             String                    @id @default(cuid())
  schoolId       String
  subscriptionId String?
  subscription   Subscription?             @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  tier           Tier
  amount         Decimal                   @db.Decimal(12, 2)
  currency       String                    @default("GHS")
  studentCount   Int
  periodStart    DateTime
  periodEnd      DateTime
  status         SubscriptionInvoiceStatus @default(PENDING)
  /// Our own reference, sent to the gateway and echoed back on the webhook.
  reference      String                    @unique
  provider       GatewayProvider?
  /// Gateway's transaction id, once it settles.
  externalId     String?
  paidAt         DateTime?
  createdById    String?
  createdAt      DateTime                  @default(now())

  @@index([schoolId, createdAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Concession rules — scholarships, bursaries, staff-child and sibling discounts
//
// A rule is a *policy*, not money. It decides how much DISCOUNT to append to the ledger when a
// term is invoiced; the ledger remains the only record of what is owed. Nothing here is ever
// summed to produce a balance.
// ─────────────────────────────────────────────────────────────────────────────

enum ConcessionKind {
  /// Awarded to named students — merit, bursary, staff child.
  SCHOLARSHIP
  /// Applied automatically to families with more than one child on the roll.
  SIBLING
}

enum ConcessionBasis {
  PERCENT
  AMOUNT
}

model ConcessionRule {
  id       String          @id @default(cuid())
  schoolId String
  name     String
  kind     ConcessionKind
  basis    ConcessionBasis
  /// A percentage (0–100) or a flat amount in the school's currency, per `basis`.
  value    Decimal         @db.Decimal(12, 2)
  /// SIBLING only: the child this starts applying from, counting eldest first. 2 = "second
  /// child onward", which is how schools actually describe it.
  fromSibling Int?
  /// Restrict to one level; null applies school-wide.
  levelId  String?
  level    Level?          @relation(fields: [levelId], references: [id], onDelete: Cascade)
  active   Boolean         @default(true)
  /// Optional window. A scholarship awarded for one year should not quietly run forever.
  startsOn DateTime?
  endsOn   DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  awards ConcessionAward[]

  /// Rules stack, so two rules with the same name would silently double a discount. A school
  /// wanting two genuinely different scholarships names them differently.
  @@unique([schoolId, name])
  @@index([schoolId, active])
}

/// A named student holding a SCHOLARSHIP rule. Sibling rules need no award — they are worked
/// out from the family each time invoices are raised.
model ConcessionAward {
  id        String         @id @default(cuid())
  schoolId  String
  ruleId    String
  rule      ConcessionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  studentId String
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  /// Why this child — a scholarship without a stated reason is a favour, not a policy.
  reason    String
  awardedById String?
  createdAt DateTime       @default(now())

  @@unique([ruleId, studentId])
  @@index([schoolId, studentId])
}
