// EYO SMS — core schema (Phase 1: SIS, attendance, assessment, fees)
// Rules: every tenant-owned table carries schoolId; the fee ledger is append-only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── The school, its people, and its licence ──────────────────────────

enum Tier {
  BASIC
  MEDIUM
  ADVANCED
}

/// Terminal-report layout. GES is the statutory-looking default; MODERN is a cleaner
/// alternative some private schools prefer (docs/02 §2.3).
enum ReportTemplate {
  GES
  MODERN
}

/// What kind of principal an account is — no longer what job the person does.
///
/// This began as the whole access model and is now down to one question: is this the proprietor,
/// ordinary staff, a guardian, or a student? What a member of staff may actually do comes from
/// their StaffRole and its permissions. HEAD/BURSAR/TEACHER/FRONT_DESK are kept because existing
/// accounts carry them and they cost nothing; new staff accounts are simply STAFF, because asking
/// a school to pick one of five job titles that grant nothing was asking them to describe a person
/// twice and get it wrong once.
enum Role {
  /// The proprietor. The only value that still confers anything: they hold every permission,
  /// cannot be narrowed, and only a proprietor may create or manage another.
  OWNER
  /// Anyone else who signs in to run the school. Their StaffRole says what they may do.
  STAFF
  /// Retained for accounts created before the account-type choice was retired.
  HEAD
  BURSAR
  TEACHER
  FRONT_DESK
  GUARDIAN
  /// Students authenticate through their own portal (admission number + PIN), not the staff
  /// login; the role exists so RBAC can name them (docs/02 §2.10).
  STUDENT
}

model School {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  motto     String?
  address   String?
  phone     String?
  email     String?
  region    String?
  country   String   @default("GH")
  website   String?
  currency  String   @default("GHS")
  tier      Tier     @default(BASIC)
  /// Storage key for the school crest. Bytes are served by GET /school/logo, never a public URL.
  logoUrl   String?
  /// What the crest actually is. Without it every crest was served as image/png, including the
  /// jpeg and webp ones — browsers sniff and cope, but the login page now serves this to the
  /// whole internet and guessing a content type there is not on.
  logoMimeType String?
  /// Hex brand colour applied to primary surfaces (sidebar, top bar, primary buttons).
  brandColor String? @db.VarChar(7)
  smsSenderId String? // registered SMS sender ID (e.g. "BRIGHTON")
  smsCredits  Int      @default(0) // pay-as-you-go SMS units the school has bought
  reportTemplate ReportTemplate @default(GES)
  /// Whether a family with an outstanding balance is held back from reading a published report.
  ///
  /// Near-universal practice in Ghanaian private schools ("no fees, no report card"), and off by
  /// default because it is a policy a school chooses, not one the software should assume. It
  /// withholds from the *family*; staff always see every report, and the school can clear an
  /// individual child without clearing the policy (see FeeClearance).
  reportsRequireFeeClearance Boolean @default(false)
  /// How the two halves of a subject mark are weighted. GES convention is 30/70, but schools
  /// differ and early years often run 100/0.
  sbaWeight  Int @default(30)
  examWeight Int @default(70)
  /// How this school numbers its students, e.g. `BA-{YYYY}-{####}`.
  ///
  /// Every school already has a house style, printed on report cards, ID cards and the register.
  /// Imposing ours would mean two numbers for every child. See common/admission-no.ts.
  admissionNoFormat String @default("{YYYY}-{####}")
  /// The next number in the school's own run. Held here rather than counted from the students
  /// table so that withdrawing a child never causes the next enrolment to reuse their number.
  admissionNoNext   Int    @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  academicYears AcademicYear[]
  levels        Level[]
  classes       ClassRoom[]
  subjects      Subject[]
  students      Student[]
  guardians     Guardian[]

  staffRoles    StaffRole[]
  passwordResets PasswordReset[]
}

model User {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  name         String
  email        String   @unique
  /// Teacher licence number from the National Teaching Council, and the qualification behind it.
  /// NaSIA inspections ask for the staff list with these on it, and so does the annual census.
  ntcNumber     String?
  qualification String?
  dutyTurns     DutyRoster[]
  lessonNotes   LessonNote[]  @relation("LessonNoteTeacher")
  phone        String?
  passwordHash String
  /// Legacy coarse role. Retained because it still identifies the proprietor (OWNER always holds
  /// every permission) and because guardians and students are principals of a different kind.
  /// Day-to-day authority now comes from `staffRole`.
  role         Role
  /// The school-defined role this person holds. Null only for the proprietor and for non-staff
  /// principals, who do not take their authority from a role row.
  staffRoleId  String?
  staffRole    StaffRole? @relation(fields: [staffRoleId], references: [id], onDelete: SetNull)
  /// Permissions granted or revoked for this one person, on top of their role.
  ///
  /// Deliberately narrow: a school with one teacher who also covers the gate should not need a
  /// whole new role. Revocations win over grants, so taking something away is always decisive.
  extraPermissions   String[] @default([])
  revokedPermissions String[] @default([])
  active       Boolean  @default(true)
  /// Bumped to invalidate every token already issued to this person.
  ///
  /// Tokens live 12 hours and there is no session table to delete from, so before this a changed
  /// password did nothing to the sessions that password had already opened — the whole point of
  /// changing it after a laptop goes missing. The guard compares this against the claim in the
  /// token on the lookup it already performs, so revocation costs no extra query.
  ///
  /// Existing tokens carry no claim at all; those read as 0 and so match the default, which is
  /// why shipping this does not sign out every school at once.
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])

  timetableSlots TimetableSlot[]
  passwordResets PasswordReset[]
  staffAttendance StaffAttendanceRecord[]
  leaveRequests   LeaveRequest[]
  reliefCovers    Substitution[] @relation("ReliefCover")
  payProfile      StaffPayProfile?
}

/// A staff password-reset request, issued by email and usable once.
///
/// Deliberately a table rather than a signed stateless token: a reset link must stop working the
/// moment it is used or superseded, and a JWT cannot be withdrawn. `consumedAt` and the
/// supersede-on-issue rule below both need somewhere to write.
/// How a reset token was delivered, and therefore what shape it takes.
enum PasswordResetChannel {
  EMAIL
  SMS
}

model PasswordReset {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 of the token that was sent. The token itself is never stored, so a leaked
  /// database yields no working reset links.
  ///
  /// For EMAIL this is the hash of a 32-byte link token. For SMS it is the hash of `codeSalt`
  /// plus a six-digit code, which is what makes this column unique for codes too: without the
  /// salt, one person asking twice could draw the same six digits and collide on the constraint,
  /// turning a reset request into a 500.
  tokenHash String @unique
  /// Random per row, and only for SMS. Never sent anywhere — it exists to keep `tokenHash`
  /// unique and to stop a leaked table from being a million-entry rainbow lookup.
  codeSalt  String?
  /// How the token reached the person, and so what shape it is: a link for EMAIL, a code for SMS.
  channel   PasswordResetChannel @default(EMAIL)
  /// Wrong codes tried against this row.
  ///
  /// Only SMS can meaningfully be guessed — six digits is a million possibilities, which is
  /// nothing at network speed without a ceiling. A link token is 32 random bytes and needs no
  /// such counter.
  attempts  Int      @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  /// Set when a newer request replaces this one, so only the most recent email works.
  supersededAt DateTime?
  /// Recorded to investigate a reset nobody asked for. Not used for authorisation.
  requestedIp String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  /// The code path finds a person's most recent live SMS request rather than hashing to a row.
  @@index([userId, channel, createdAt])
  @@index([expiresAt])
}

/// Failed sign-in attempts, so a password cannot be guessed at machine speed.
///
/// Keyed by the address **as typed**, not by a user row, and written for addresses with no
/// account as readily as for real ones. That is deliberate: the lockout reply below names the
/// wait, and if only real accounts could reach it the message would become a perfectly reliable
/// account-existence oracle — undoing the care taken to keep "Invalid email or password" vague.
///
/// Not tenant-owned. Sign-in happens before any school is known, so this is reached through the
/// system client, and RLS is left on with no policy so the app role can never read it.
model LoginThrottle {
  email         String    @id
  failedCount   Int       @default(0)
  /// Start of the current counting window. Failures older than the window do not accumulate —
  /// a teacher who fumbles their password twice a month is not on their way to a lockout.
  firstFailedAt DateTime  @default(now())
  lockedUntil   DateTime?
  updatedAt     DateTime  @updatedAt

  /// For the sweep of settled rows. Addresses that eventually sign in delete their own row, but
  /// an address that never does — which is what a spray of invented addresses looks like — would
  /// otherwise sit here forever.
  @@index([updatedAt])
}

/// A named bundle of permissions, owned and editable by the school.
///
/// Seeded from the presets in common/permissions.ts, which follow how private schools actually
/// staff — head, assistant head, head of department, class and subject teacher, exams officer,
/// bursar, accounts clerk, registrar, front desk, nurse, librarian, IT administrator. A school
/// may rename, re-scope or delete any of them, or invent its own.
model StaffRole {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  description String?
  /// Permission codes, validated against the registry on write so a renamed permission cannot be
  /// resurrected by an old row.
  permissions String[] @default([])
  /// Stable key of the preset this came from; null for a school's own invention. Marks
  /// provenance only — presets are fully editable.
  presetKey   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  detail    Json?
  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
}

// ── Academic structure ───────────────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  /// Set when the school formally closes the year, after every term in it is closed and the
  /// promotion run has moved the children on. Distinct from `isCurrent`, which only says which
  /// year the software is pointing at — a year can stop being current without ever being finished.
  closedAt   DateTime?
  closedById String?
  terms     Term[]
  promotions PromotionRecord[]
  mockSeries MockSeries[]

  @@unique([schoolId, name])
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  name           String
  startDate      DateTime
  endDate        DateTime
  nextTermBegins DateTime?
  isCurrent      Boolean      @default(false)
  /// Set when the school closes the term: exams marked, reports vetted and published, returns
  /// filed. A closed term stops accepting attendance, scores and report generation — its academic
  /// record is settled history. Money is deliberately *not* frozen: arrears carry forward and a
  /// parent may still pay last term's bill months later.
  closedAt   DateTime?
  closedById String?

  feeClearances FeeClearance[]

  @@unique([academicYearId, name])
}

enum LevelCategory {
  PRE_SCHOOL
  PRIMARY
  JHS
  SHS
}

model Level {
  id              String         @id @default(cuid())
  schoolId        String
  school          School         @relation(fields: [schoolId], references: [id])
  name            String
  category        LevelCategory
  /// Short code for the admission-number format, e.g. PRI or JHS. Optional.
  code            String?
  order           Int
  gradingSchemeId String? // which grading scheme this level's reports use (per-level selection)
  gradingScheme   GradingScheme? @relation(fields: [gradingSchemeId], references: [id])
  classes         ClassRoom[]
  components      AssessmentComponent[]
  syllabusTopics  SyllabusTopic[]
  questionBanks   QuestionBank[]

  @@unique([schoolId, name])

  applicants           Applicant[]
  customFields         CustomFieldDef[]
  documentRequirements DocumentRequirement[]
  calendarEvents       CalendarEvent[]
  learningResources    LearningResource[]
  concessionRules ConcessionRule[]
}

/// A physical site of one school (FEATURES.md §1: several campuses under one school). Classes
/// belong to a campus; students derive theirs through their class. One school, one licence,
/// one database — a campus is a label with an address, not a tenant.
model Campus {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  address   String?
  createdAt DateTime @default(now())

  classes ClassRoom[]

  @@unique([schoolId, name])
}

model ClassRoom {
  id            String    @id @default(cuid())
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id])
  levelId       String
  level         Level     @relation(fields: [levelId], references: [id])
  /// Null means the school's single (or main) site. Deleting a campus frees its classes
  /// rather than taking them down.
  campusId      String?
  campus        Campus?   @relation(fields: [campusId], references: [id], onDelete: SetNull)
  name          String
  classTeacherId String?
  students      Student[]

  @@unique([schoolId, name])

  learningResources LearningResource[]
  timetableSlots    TimetableSlot[]
  syllabusCoverage  SyllabusCoverage[]
}

model Subject {
  id       String  @id @default(cuid())
  schoolId String
  school   School  @relation(fields: [schoolId], references: [id])
  name     String
  code     String
  isCore   Boolean @default(false)

  components AssessmentComponent[]

  @@unique([schoolId, code])

  learningResources LearningResource[]
  timetableSlots    TimetableSlot[]
  syllabusTopics    SyllabusTopic[]
  questionBanks     QuestionBank[]
  mockResults       MockResult[]
}

// ── Students & guardians ─────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  TRANSFERRED
  WITHDRAWN
  GRADUATED
}

enum Gender {
  MALE
  FEMALE
}

model Student {
  id           String        @id @default(cuid())
  schoolId     String
  school       School        @relation(fields: [schoolId], references: [id])
  admissionNo  String
  firstName    String
  lastName     String
  otherNames   String?
  gender       Gender
  dateOfBirth  DateTime
  photoUrl     String?
  classId      String?
  classRoom    ClassRoom?    @relation(fields: [classId], references: [id])
  status       StudentStatus @default(ACTIVE)
  enrolledAt   DateTime      @default(now())
  exitDate     DateTime? // set on transfer / withdrawal / graduation
  exitReason   String?
  medicalNotes String?
  /// The child's name exactly as it appears on the birth certificate, when that differs from the
  /// name the school uses day to day. WAEC prints certificates from what is registered and a
  /// mismatch blocks a candidate outright — chronically, and always discovered too late.
  certificateName String?
  /// Hash of the portal PIN the school issues. Null until a PIN is set; students without one
  /// simply cannot sign in, which is the right default for the youngest classes.
  portalPinHash String?
  /// Failed portal sign-in attempts since the last success, and how long the account is barred.
  /// A six-digit PIN is trivially brute-forced without this, and it belongs to a child.
  portalPinFails Int      @default(0)
  portalLockedUntil DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  guardians    StudentGuardian[]
  attendance   AttendanceRecord[]
  scores       Score[]
  termReports  TermReport[]
  feeClearances FeeClearance[]
  promotions   PromotionRecord[]
  csspsChoices CsspsChoice[]
  mockResults  MockResult[]
  disciplineEntries DisciplineEntry[]
  feedingRecords FeedingRecord[]
  invoices     Invoice[]
  ledger       LedgerEntry[]
  documents      StudentDocument[]
  bankDeposits   BankDeposit[]
  paymentIntents PaymentIntent[]
  feeItems       StudentFeeItem[]
  pickupDelegates PickupDelegate[]
  releases        ReleaseLog[]
  checkIns        CheckInLog[]
  dismissalRequests DismissalRequest[]
  transportRider  TransportRider?
  transportScans  TransportScan[]
  cbtAttempts     CbtAttempt[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId, classId])

  installments      Installment[]
  fieldValues       StudentFieldValue[]
  concessionAwards ConcessionAward[]
}

/// Files attached to a student (birth certificate, immunisation card, previous report…).
/// `key` addresses the object in storage; bytes are never stored in the database.
model StudentDocument {
  id           String   @id @default(cuid())
  schoolId     String
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  kind         String   @default("OTHER")
  filename     String
  contentType  String
  size         Int
  key          String
  uploadedById String
  createdAt    DateTime @default(now())

  @@index([schoolId, studentId])
}

/// Papers attached to an applicant — a birth certificate, a previous report. On enrolment they
/// become StudentDocument rows (same storage keys), so nothing is re-uploaded.
model ApplicantDocument {
  id           String    @id @default(cuid())
  schoolId     String
  applicantId  String
  applicant    Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  kind         String    @default("OTHER")
  filename     String
  contentType  String
  size         Int
  key          String
  uploadedById String
  createdAt    DateTime  @default(now())

  @@index([schoolId, applicantId])
}

enum DepositStatus {
  PENDING
  CONFIRMED
  REJECTED
}

/// A bank deposit claimed by a guardian/office with proof attached. Nothing reaches the
/// ledger until a bursar confirms it — confirmation appends a PAYMENT entry + receipt.
model BankDeposit {
  id            String        @id @default(cuid())
  schoolId      String
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])
  termId        String?
  amount        Decimal       @db.Decimal(12, 2)
  bankName      String?
  bankRef       String?
  depositedAt   DateTime
  proofKey      String?
  status        DepositStatus @default(PENDING)
  /// Reference of the ledger entry created on confirmation — also the idempotency key.
  /// Per-school for the same reason as LedgerEntry.reference.
  reference     String
  note          String?
  reviewNote    String?
  submittedById String
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())

  @@index([schoolId, status])
  @@unique([schoolId, reference])
}

enum CustodyFlag {
  NONE
  RESTRICTED
  BLOCKED
}

model Guardian {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  firstName     String
  lastName      String
  phone         String
  email         String?
  whatsappOptIn Boolean  @default(false)
  createdAt     DateTime @default(now())

  students StudentGuardian[]
  otps     GuardianOtp[]
  pickupCredential PickupCredential?
  dismissalRequests DismissalRequest[]
  carLineEntries    CarLineEntry[]

  @@index([schoolId, phone])

  /// Storage key for a face photo, shown to gate staff at handoff. Bytes are served through the
  /// API, never a public URL — this is a picture of a person attached to a named child.
  photoUrl String?

  whatsappConversations WhatsAppConversation[]
}

/// One-time sign-in codes for the guardian portal. Only a hash of the code is stored, so a
/// database leak cannot be replayed into guardian accounts.
model GuardianOtp {
  id         String    @id @default(cuid())
  schoolId   String
  guardianId String
  guardian   Guardian  @relation(fields: [guardianId], references: [id])
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([guardianId])
}

model StudentGuardian {
  studentId    String
  student      Student     @relation(fields: [studentId], references: [id])
  guardianId   String
  guardian     Guardian    @relation(fields: [guardianId], references: [id])
  relationship String
  isPrimary    Boolean     @default(false)
  canPickup    Boolean     @default(true)
  custodyFlag  CustodyFlag @default(NONE)

  @@id([studentId, guardianId])
}

// ── Attendance ───────────────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  schoolId   String
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id])
  classId    String
  termId     String
  date       DateTime         @db.Date
  status     AttendanceStatus
  markedById String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, date])
  @@index([schoolId, classId, date])
}

// ── Assessment & terminal reports ────────────────────────────────────

enum GradingKind {
  GES_CLASSIC
  NACCA_BANDS
  EARLY_YEARS
}

model GradingScheme {
  id       String      @id @default(cuid())
  schoolId String
  name     String
  kind     GradingKind
  /// bands: [{ min, max, grade, remark }] — for NaCCA/early-years, `grade` carries the proficiency label
  bands    Json
  levels   Level[]

  @@unique([schoolId, name])
}

/// Continuous assessment counts toward the SBA portion; exams toward the exam portion. A
/// subject may have any number of each — three class tests and two papers is as valid as one
/// of each.
enum AssessmentCategory {
  CONTINUOUS
  EXAM
}

/// One markable item: a class test, an assignment, a project, an end-of-term paper.
///
/// Scope narrows from the school down: a component with no subject and no level applies
/// everywhere, one with a subject applies to that subject in every class, one with both applies
/// only there. That is what lets JHS 2 Science have a practical that no other subject has,
/// without forcing every class to carry the same four columns.
model AssessmentComponent {
  id        String             @id @default(cuid())
  schoolId  String
  name      String
  maxScore  Int
  category  AssessmentCategory @default(CONTINUOUS)
  /// Null means every subject.
  subjectId String?
  subject   Subject?           @relation(fields: [subjectId], references: [id])
  /// Null means every level.
  levelId   String?
  level     Level?             @relation(fields: [levelId], references: [id])
  order     Int                @default(0)
  createdAt DateTime           @default(now())

  scores Score[]

  @@index([schoolId, subjectId, levelId])
}

model Score {
  id          String              @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student             @relation(fields: [studentId], references: [id])
  subjectId   String
  termId      String
  componentId String
  component   AssessmentComponent @relation(fields: [componentId], references: [id])
  rawScore    Float
  enteredById String
  updatedAt   DateTime            @updatedAt

  @@unique([studentId, subjectId, termId, componentId])
  @@index([schoolId, termId, subjectId])
}

model TermReport {
  id                String    @id @default(cuid())
  schoolId          String
  studentId         String
  student           Student   @relation(fields: [studentId], references: [id])
  termId            String
  classId           String
  /// lines: [{ subject, sba30, exam70, total, grade, remark, position }]
  lines             Json
  overallTotal      Float
  classPosition     Int?
  classSize         Int?
  attendancePresent Int       @default(0)
  attendanceTotal   Int       @default(0)
  conduct           String?
  interest          String?
  teacherRemark     String?
  headRemark        String?
  publishedAt       DateTime?
  /// Set when the head has read the report and is content with it, before it is released.
  ///
  /// The order a Ghanaian school actually works in is generate → vet → publish, and the vetting is
  /// the head reading every card. Without a state for it, "checked" lived in somebody's memory and
  /// the only visible difference between a vetted report and an unread one was that a human had
  /// scrolled past it.
  vettedAt          DateTime?
  vettedById        String?
  generatedAt       DateTime  @default(now())

  @@unique([studentId, termId])
  @@index([schoolId, termId, classId])
}

/// A mock examination series — "Mock 1", "District Mock", "Second Mock".
///
/// Deliberately not a Term. A JHS3 candidate sits three to six mocks in their final year, all
/// inside one term, each producing a full set of subject marks and a BECE-style aggregate. Modelled
/// as a term they would each need their own fee structure, register and report cards; modelled as
/// assessment components they would be folded into the terminal report, which is exactly what a
/// mock must not do. So they are their own thing, hanging off the year rather than the term.
model MockSeries {
  id             String       @id @default(cuid())
  schoolId       String
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name           String
  /// When it was sat. Null while it is still being set up.
  sittingOn      DateTime?
  /// The candidate class, when the series is for one class rather than a whole year group.
  classId        String?
  createdById    String
  createdAt      DateTime     @default(now())
  results        MockResult[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId, academicYearId])
}

/// One candidate's mark in one subject in one mock. Out of 100: a mock is a whole paper, so there
/// is no SBA half to weight against.
model MockResult {
  id        String     @id @default(cuid())
  schoolId  String
  seriesId  String
  series    MockSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  studentId String
  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  total     Float
  updatedAt DateTime   @updatedAt

  @@unique([seriesId, studentId, subjectId])
  @@index([schoolId, seriesId])
}

// ── The registers an inspection asks for ─────────────────────────────
//
// NaSIA licenses and inspects private schools, and the inspection is largely a request to see
// books: the admission register, the attendance registers, the log book, the visitors book. Four
// of those the software already held in some form. These are the ones it did not, and they are
// the reason a school still keeps a shelf of ledgers next to a system that has everything else.

enum LogBookKind {
  GENERAL
  VISIT
  INCIDENT
  ABSENCE
  MAINTENANCE
}

/// The head's (or duty teacher's) daily record of anything worth remembering about a day.
///
/// Free-form on purpose. A log book entry is "the water went off at 11", "district officer called
/// unannounced", "P4 window broken during break" — the value is that it is dated, attributed and
/// unalterable, not that it is structured.
model LogBookEntry {
  id        String      @id @default(cuid())
  schoolId  String
  /// The day being recorded, which is not always the day it was written.
  entryDate DateTime
  kind      LogBookKind @default(GENERAL)
  body      String
  authorId  String
  createdAt DateTime    @default(now())

  @@index([schoolId, entryDate])
}

/// Who is on duty, and when. The duty teacher runs assembly, supervises break and closing, and
/// writes the day into the log book — so the roster is what says whose entry is missing.
model DutyRoster {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Inclusive range; a duty turn is usually a week, occasionally a single day.
  startDate DateTime
  endDate   DateTime
  note      String?
  createdAt DateTime @default(now())

  @@index([schoolId, startDate])
}

enum VettingStatus {
  SUBMITTED
  APPROVED
  RETURNED
}

/// A teacher's lesson notes or scheme of work, submitted for the head to vet.
///
/// Weekly, and universal in Ghanaian schools: the head reads and signs lesson notes before the
/// week they cover. Modelled as a submission with a decision rather than a file store, because
/// the workflow — submitted, seen, returned with a comment — is the part that lives on paper.
model LessonNote {
  id         String        @id @default(cuid())
  schoolId   String
  teacherId  String
  teacher    User          @relation("LessonNoteTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  classId    String?
  subjectId  String?
  /// The week the notes cover, by its Monday.
  weekOf     DateTime
  title      String
  body       String?
  /// Optional attachment in object storage, for a school that types notes up elsewhere.
  fileKey    String?
  fileName   String?
  status     VettingStatus @default(SUBMITTED)
  vettedById String?
  vettedAt   DateTime?
  /// The head's comment. Required when returning — "redo it" without a reason is not vetting.
  comment    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([schoolId, weekOf])
  @@index([schoolId, teacherId])
}

enum DisciplineOutcome {
  RECORDED
  WARNED
  PARENT_INFORMED
  SUSPENDED
  RESOLVED
}

/// The discipline book, in the shape a school actually keeps it.
///
/// Corporal punishment is banned by GES, so this records what happened and what was done about
/// it, never a sanction to be administered. The escalation trail matters more than the incident:
/// "class teacher → section head → head" is how these are handled, and a parent asking why their
/// child was suspended is asking to see that trail.
model DisciplineEntry {
  id           String            @id @default(cuid())
  schoolId     String
  studentId    String
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  occurredOn   DateTime
  description  String
  actionTaken  String?
  outcome      DisciplineOutcome @default(RECORDED)
  /// Set when the school told the family, which is the fact most often disputed later.
  guardianInformedAt DateTime?
  recordedById String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([schoolId, occurredOn])
  @@index([schoolId, studentId])
}

/// The visitors book at the front desk — adults on the compound who are not collecting a child.
///
/// Deliberately separate from the gate log, which is about pupils. A safeguarding question after
/// the fact ("who was in the building on Tuesday?") is answered by this book and by nothing else.
model VisitorLog {
  id           String    @id @default(cuid())
  schoolId     String
  name         String
  phone        String?
  organisation String?
  purpose      String
  /// Who they came to see, in the school's own words rather than a foreign key: visitors ask for
  /// "the bursar" as often as for a person, and the record should say what was actually said.
  toSee        String?
  arrivedAt    DateTime  @default(now())
  departedAt   DateTime?
  badgeNo      String?
  recordedById String

  @@index([schoolId, arrivedAt])
}

/// A day's feeding money for one child.
///
/// Collected daily in cash at the majority of Ghanaian basic schools, and quite separate from the
/// termly bill: the amount is small, it is taken at the classroom door, and it is reconciled the
/// same afternoon. Modelling it as a fee item would put it on the child's ledger and make every
/// unpaid lunch an arrear, which is not what a school means by it.
model FeedingRecord {
  id           String   @id @default(cuid())
  schoolId     String
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  onDate       DateTime
  amount       Decimal  @db.Decimal(10, 2)
  collectedById String
  createdAt    DateTime @default(now())

  /// One record per child per day: a second collection is a correction, not another lunch.
  @@unique([studentId, onDate])
  @@index([schoolId, onDate])
}

/// A BECE candidate's ranked choice of senior high school, for the CSSPS placement forms.
///
/// The choices are made *before* the exam and administered by the JHS, so the school is the one
/// holding them — on paper, until now. 2026 raised the list from seven schools to eight and added
/// category rules, which is exactly the kind of thing a paper form gets wrong quietly.
model CsspsChoice {
  id         String   @id @default(cuid())
  schoolId   String
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  /// 1 is the candidate's first choice.
  rank       Int
  schoolName String
  programme  String?
  /// A–D as published by CSSPS; kept as free text because the categories are reissued yearly.
  category   String?
  /// Boarding or day, which the placement rules treat differently.
  residency  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([studentId, rank])
  @@index([schoolId, studentId])
}

enum PromotionAction {
  PROMOTED
  REPEATED
  GRADUATED
}

/// What happened to one child at the end of one academic year.
///
/// Repeating a year is a fact about a child's schooling that a parent will ask about years later,
/// and before this it left no trace at all: promotion was an `updateMany` that moved a class, so
/// a child held back was simply a child whose `classId` did not change. Absence of a change is
/// not a record. This is what the cumulative record card reads to say "repeated Basic 4".
model PromotionRecord {
  id             String          @id @default(cuid())
  schoolId       String
  studentId      String
  student        Student         @relation(fields: [studentId], references: [id])
  academicYearId String
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  action         PromotionAction
  fromClassId    String?
  /// Null for a repeat (they stay) and for a graduation (they leave).
  toClassId      String?
  decidedById    String
  createdAt      DateTime        @default(now())

  @@unique([studentId, academicYearId])
  @@index([schoolId, academicYearId])
}

/// One child let through the fee-clearance gate for one term, despite a balance.
///
/// The gate is a blunt policy and the exceptions are the entire reason it is workable: a family on
/// an agreed payment plan, a scholarship still being processed, a bereavement. Recording the
/// reason matters for the same reason it does on a scholarship — a clearance without a stated
/// reason is a favour, not a decision, and the next bursar cannot tell them apart.
model FeeClearance {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  termId      String
  term        Term     @relation(fields: [termId], references: [id])
  reason      String
  grantedById String
  createdAt   DateTime @default(now())

  @@unique([studentId, termId])
  @@index([schoolId, termId])
}

// ── Fees: append-only ledger ─────────────────────────────────────────

model FeeItem {
  id       String  @id @default(cuid())
  schoolId String
  termId   String
  levelId  String?
  name     String
  amount   Decimal @db.Decimal(12, 2)
  /// Optional items (transport, feeding) are billed only to the students subscribed to them.
  optional Boolean @default(false)

  subscriptions StudentFeeItem[]

  @@index([schoolId, termId])
}

/// Which students have taken up an optional fee item this term. Compulsory items need no such
/// row — everyone gets them.
model StudentFeeItem {
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  feeItemId String
  feeItem   FeeItem  @relation(fields: [feeItemId], references: [id], onDelete: Cascade)
  schoolId  String
  createdAt DateTime @default(now())

  @@id([studentId, feeItemId])
  @@index([schoolId])
}

model Invoice {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  termId    String
  number    String
  /// lines: [{ name, amount }]
  lines     Json
  total     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  paymentIntents PaymentIntent[]

  @@unique([schoolId, number])
  @@unique([studentId, termId])
  @@index([schoolId, termId])

  installments Installment[]
}

enum LedgerType {
  INVOICE
  PAYMENT
  DISCOUNT
  WAIVER
  REVERSAL
}

enum PaymentMethod {
  CASH
  BANK
  MOMO
  CARD
}

/// Append-only. Never updated, never deleted. Corrections are REVERSAL entries.
model LedgerEntry {
  id          String         @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student        @relation(fields: [studentId], references: [id])
  termId      String?
  type        LedgerType
  /// Positive amounts. INVOICE increases balance owed; PAYMENT/DISCOUNT/WAIVER decrease it;
  /// REVERSAL negates the entry it references (reversedId).
  amount      Decimal        @db.Decimal(12, 2)
  method      PaymentMethod?
  /// Unique per school, not globally. Numbering is per-school (PAY-2026-00001 for every
  /// school's first cash payment), so a global constraint meant the SECOND school to take money
  /// collided with the first and could not record the payment at all.
  reference   String
  reversedId  String?
  note        String?
  createdById String
  createdAt   DateTime       @default(now())

  receipt Receipt?

  @@index([schoolId, studentId])
  @@index([schoolId, createdAt])
  @@unique([schoolId, reference])
}

/// Per-school counters for human-facing document numbers (receipts, payments, invoices).
///
/// These were each derived from `count(rows) + 1`, which is not a counter: two clerks taking
/// money at the same moment both read the same total and both claim the same receipt number.
/// One insert then loses the unique index — and because the whole request runs in one
/// transaction, the loser's ledger entry is discarded with it. Held here and incremented
/// atomically, the way `School.admissionNoNext` already is.
model NumberSequence {
  id       String @id @default(cuid())
  schoolId String
  /// RECEIPT | PAYMENT | INVOICE
  name     String
  next     Int    @default(1)

  @@unique([schoolId, name])
}

model Receipt {
  id            String      @id @default(cuid())
  schoolId      String
  ledgerEntryId String      @unique
  ledgerEntry   LedgerEntry @relation(fields: [ledgerEntryId], references: [id])
  number        String
  issuedAt      DateTime    @default(now())

  @@unique([schoolId, number])
}

// ── Online payments (Medium: fees.online) ────────────────────────────

enum GatewayProvider {
  HUBTEL
  PAYSTACK
  FLUTTERWAVE
  MOCK
}

enum GatewayMode {
  TEST
  LIVE
}

enum PaymentChannel {
  MOMO
  CARD
  USSD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

/// Per-school merchant credentials. `secretEnc` is AES-256-GCM ciphertext (common/crypto.ts);
/// plaintext secrets are never stored or returned by the API.
model GatewayAccount {
  id             String          @id @default(cuid())
  schoolId       String
  provider       GatewayProvider
  mode           GatewayMode     @default(TEST)
  publicKey      String?
  secretEnc      String
  merchantNumber String? // Hubtel merchant account number
  subaccountCode String? // Paystack subaccount, if split settlement is used
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([schoolId, provider])
}

/// One attempt to collect money. Only a SUCCESS ever writes to the ledger, and it does so
/// with `reference` — LedgerEntry.reference is unique, which makes application idempotent.
model PaymentIntent {
  id          String          @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id])
  invoiceId   String?
  invoice     Invoice?        @relation(fields: [invoiceId], references: [id])
  termId      String?
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("GHS")
  reference   String          @unique
  provider    GatewayProvider
  channel     PaymentChannel
  status      PaymentStatus   @default(PENDING)
  providerRef String?
  checkoutUrl String?
  /// Opaque token for the public (unauthenticated) pay link shared with guardians.
  payToken    String?         @unique
  payerPhone  String?
  failureCode String?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([schoolId, status])
  @@index([schoolId, createdAt])
}

/// Raw gateway callbacks. `providerEventId` is unique so a replayed webhook is a no-op.
model WebhookEvent {
  id              String          @id @default(cuid())
  provider        GatewayProvider
  providerEventId String
  schoolId        String?
  reference       String?
  verified        Boolean         @default(false)
  payload         Json
  error           String?
  receivedAt      DateTime        @default(now())
  processedAt     DateTime?

  @@unique([provider, providerEventId])
  @@index([reference])
}

// ── Communication ────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  schoolId    String
  title       String
  body        String
  audience    String    @default("ALL")
  /// Set when this notice was emitted by a Broadcast rather than posted straight to the board.
  broadcastId String?
  /// Who the notice is *for*, as opposed to `audience`, which is only which portal shows it.
  /// All null means the whole school. A broadcast sent to one class used to text that class and
  /// then post the same words to every family's notice board, so "one class" was never true of
  /// more than half the send.
  classId     String?
  levelId     String?
  routeId     String?
  createdById String
  publishedAt DateTime  @default(now())

  @@index([schoolId, publishedAt])
}

enum SmsStatus {
  QUEUED
  SENT
  FAILED
}

/// Outbound bulk-SMS log. One row per recipient; `cost` debits School.smsCredits.
model SmsMessage {
  id          String    @id @default(cuid())
  schoolId    String
  to          String
  body        String
  status      SmsStatus @default(QUEUED)
  provider    String    @default("mock")
  providerRef String?
  cost        Int       @default(1)
  batchId     String?
  /// Set when this text was sent by a Broadcast rather than the messaging screen.
  broadcastId String?
  error       String?
  createdById String
  createdAt   DateTime  @default(now())

  @@index([schoolId, createdAt])
  @@index([schoolId, batchId])
}

// ── Pickup & drop-off safety (docs/02 §2.5) ──────────────────────────

/// Someone other than a guardian who may collect a child — a driver, an aunt, a neighbour.
/// Time-limited by default, because "just this term" is how these arrangements actually work.
model PickupDelegate {
  id           String    @id @default(cuid())
  schoolId     String
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id])
  name         String
  phone        String
  relationship String
  /// Always set on creation: a delegate added without a date expires with the current term,
  /// because "just this term" is how these arrangements really work.
  expiresAt    DateTime?
  /// Shown to gate staff before release, same as a guardian's photo. A card can be lent;
  /// a face cannot.
  photoUrl     String?
  active       Boolean   @default(true)
  createdById  String
  createdAt    DateTime  @default(now())

  credential PickupCredential?

  @@index([schoolId, studentId])
}

/// The credential a collector presents at the gate: a QR token on a printed card or a phone,
/// with a PIN as the fallback for guardians without a smartphone.
///
/// Only hashes of the PIN are stored, and the QR token is opaque random — a leaked database
/// must not let anyone walk out with a child.
model PickupCredential {
  id         String          @id @default(cuid())
  schoolId   String
  /// Exactly one of these is set.
  guardianId String?         @unique
  guardian   Guardian?       @relation(fields: [guardianId], references: [id])
  delegateId String?         @unique
  delegate   PickupDelegate? @relation(fields: [delegateId], references: [id], onDelete: Cascade)
  /// Looked up on scan; random and unguessable, rotated when a card is lost.
  token      String          @unique
  pinHash    String
  issuedAt   DateTime        @default(now())
  revokedAt  DateTime?

  @@index([schoolId])
}

/// How the collector was identified at the gate. Whether staff released *against advice* is a
/// separate fact, carried by overrideReason — conflating the two makes the log unreadable.
enum ReleaseMethod {
  QR
  PIN
  MANUAL
}

/// Immutable record of a child leaving: who, to whom, when, how, and who authorised it.
/// Never updated or deleted — this is the document you reach for when something goes wrong.
model ReleaseLog {
  id             String        @id @default(cuid())
  schoolId       String
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id])
  /// Name captured at the time: a delegate may later be removed, but the log must still read.
  collectedBy    String
  collectorKind  String
  collectorId    String?
  method         ReleaseMethod
  /// Set when staff released against the system's advice; carries their stated reason.
  overrideReason String?
  releasedById   String
  releasedAt     DateTime      @default(now())
  /// Idempotency key minted by the gate device before it tries to send.
  ///
  /// A release is an append, so replaying a queued one would record the same child leaving
  /// twice. This makes the write safe to retry: the second attempt finds the row and returns it
  /// instead of creating another. Without it the gate could not work offline at all.
  clientRef      String?

  @@unique([schoolId, clientRef])
  @@index([schoolId, releasedAt])
  @@index([studentId])
}

// ── External integrations (FEATURES.md §18, platform.api) ────────────

/// A key another system presents to read this school's data. Stored as a SHA-256 hash — a
/// leaked database yields no working keys — and read-only by design: outside systems observe
/// Klasio; they never write a mark or a ledger row.
model ApiKey {
  id          String    @id @default(cuid())
  schoolId    String
  name        String
  keyHash     String    @unique
  /// First 8 characters of the key, for recognising it in the list. Never enough to use.
  prefix      String
  createdById String
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  @@index([schoolId])
}

/// A school's own endpoint, told when something happens here.
///
/// The other half of "API access & webhooks": the read-only API lets another system ask, and this
/// lets Klasio tell. A school with an accounting package wants to hear about a payment when it
/// happens, not to poll every ten minutes for the rest of the term.
model Webhook {
  id          String    @id @default(cuid())
  schoolId    String
  url         String
  /// Which events to send. Empty means every event, which is what most schools want.
  events      String[]  @default([])
  /// Signing secret, shown once. The receiver verifies the signature over the exact bytes sent,
  /// the same rule the payment gateways' own webhooks are verified by.
  secret      String
  active      Boolean   @default(true)
  createdById String
  createdAt   DateTime  @default(now())
  /// Last outcome, so a school can see a dead endpoint without reading logs it has no access to.
  lastStatus  Int?
  lastError   String?
  lastSentAt  DateTime?

  @@index([schoolId])
}

// ── Computer-based tests (FEATURES.md §5, exams.cbt) ─────────────────

/// A bank of multiple-choice questions for one subject at one level.
model QuestionBank {
  id        String   @id @default(cuid())
  schoolId  String
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  levelId   String
  level     Level    @relation(fields: [levelId], references: [id])
  name      String
  createdAt DateTime @default(now())

  questions Question[]
  exams     CbtExam[]

  @@index([schoolId, subjectId, levelId])
}

model Question {
  id           String       @id @default(cuid())
  schoolId     String
  bankId       String
  bank         QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  text         String
  /// The choices in order; correctIndex points into this list.
  options      String[]
  correctIndex Int
  explanation  String?
  createdAt    DateTime     @default(now())

  @@index([schoolId, bankId])
}

enum CbtExamStatus {
  DRAFT
  OPEN
  CLOSED
}

/// A sitting composed from a bank for one class: mock BECE papers, class tests. Auto-marked.
model CbtExam {
  id              String        @id @default(cuid())
  schoolId        String
  title           String
  bankId          String
  bank            QuestionBank  @relation(fields: [bankId], references: [id])
  classId         String
  durationMinutes Int
  /// How many of the bank's questions each sitting uses (the first N by creation order, so
  /// every candidate answers the same paper).
  questionCount   Int
  status          CbtExamStatus @default(DRAFT)
  /// Optional gradebook destination: on posting, each score lands as this component's mark.
  componentId     String?
  createdById     String
  createdAt       DateTime      @default(now())

  attempts CbtAttempt[]

  @@index([schoolId, classId])
}

/// One pupil's sitting. `answers` maps questionId → chosen option index; marking is on submit.
model CbtAttempt {
  id          String    @id @default(cuid())
  schoolId    String
  examId      String
  exam        CbtExam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  answers     Json?
  score       Int?
  total       Int?

  @@unique([examId, studentId])
  @@index([schoolId, examId])
}

// ── Payroll (FEATURES.md §17, hr.payroll) ───────────────────────────

/// What one member of staff is paid, and how the money reaches them. Amounts in GHS.
model StaffPayProfile {
  id            String  @id @default(cuid())
  schoolId      String
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id])
  basicSalary   Decimal @db.Decimal(12, 2)
  /// Cash allowances, summed monthly (transport, rent, responsibility …).
  allowances    Decimal @default(0) @db.Decimal(12, 2)
  /// Standing non-statutory deduction (loan repayment, welfare dues).
  deductions    Decimal @default(0) @db.Decimal(12, 2)
  /// BANK | MOMO — which payout file this person lands in.
  payoutMethod  String  @default("BANK")
  /// Account number or MoMo wallet, and the name the bank knows them by.
  payoutAccount String?
  payoutName    String?
  updatedAt     DateTime @updatedAt

  @@index([schoolId])
}

enum PayRunStatus {
  DRAFT
  APPROVED
}

/// One month's pay for the whole staff. Lines snapshot everything at computation time — a
/// later salary change must never rewrite an approved month.
model PayRun {
  id           String       @id @default(cuid())
  schoolId     String
  /// Calendar month, as YYYY-MM.
  period       String
  status       PayRunStatus @default(DRAFT)
  createdById  String
  createdAt    DateTime     @default(now())
  approvedById String?
  approvedAt   DateTime?

  lines PayRunLine[]

  @@unique([schoolId, period])
}

model PayRunLine {
  id             String  @id @default(cuid())
  schoolId       String
  payRunId       String
  payRun         PayRun  @relation(fields: [payRunId], references: [id], onDelete: Cascade)
  userId         String
  /// Name snapshot — the payslip must still read correctly after the person leaves.
  staffName      String
  roleName       String?
  basic          Decimal @db.Decimal(12, 2)
  allowances     Decimal @db.Decimal(12, 2)
  gross          Decimal @db.Decimal(12, 2)
  ssnitEmployee  Decimal @db.Decimal(12, 2)
  taxable        Decimal @db.Decimal(12, 2)
  paye           Decimal @db.Decimal(12, 2)
  otherDeductions Decimal @default(0) @db.Decimal(12, 2)
  net            Decimal @db.Decimal(12, 2)
  ssnitEmployer  Decimal @db.Decimal(12, 2)
  payoutMethod   String  @default("BANK")
  payoutAccount  String?
  payoutName     String?

  @@unique([payRunId, userId])
  @@index([schoolId])
}

// ── School transport (FEATURES.md §10, safety.transport) ────────────

/// A bus route. Billing rides the fees module: a route may point at an optional FeeItem, and
/// assigning a rider subscribes them to it — the ledger stays the only place money lives.
model TransportRoute {
  id          String  @id @default(cuid())
  schoolId    String
  name        String
  description String?
  /// Optional fee item this route bills through (per-term transport billing).
  feeItemId   String?
  createdAt   DateTime @default(now())

  stops  TransportStop[]
  riders TransportRider[]
  scans  TransportScan[]

  @@unique([schoolId, name])
}

model TransportStop {
  id       String         @id @default(cuid())
  schoolId String
  routeId  String
  route    TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  name     String
  order    Int            @default(0)

  riders TransportRider[]

  @@index([schoolId, routeId])
}

/// Who rides which bus — the manifest. One route per child.
model TransportRider {
  id        String         @id @default(cuid())
  schoolId  String
  /// Unique on its own: one route per child, and Prisma's 1:1 needs a single-field key.
  studentId String         @unique
  student   Student        @relation(fields: [studentId], references: [id])
  routeId   String
  route     TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stopId    String?
  stop      TransportStop? @relation(fields: [stopId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@index([schoolId, routeId])
}

enum TransportDirection {
  BOARD
  ALIGHT
}

/// A child scanned on or off the bus. Immutable, idempotent via clientRef — the bus is the
/// definition of an offline device.
model TransportScan {
  id           String             @id @default(cuid())
  schoolId     String
  studentId    String
  student      Student            @relation(fields: [studentId], references: [id])
  routeId      String
  route        TransportRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  direction    TransportDirection
  recordedById String
  scannedAt    DateTime           @default(now())
  clientRef    String?

  @@unique([schoolId, clientRef])
  @@index([schoolId, scannedAt])
  @@index([studentId])
}

/// A syllabus topic for one subject at one level (FEATURES.md §6) — the unit of "have we
/// taught this yet". Ordered, so the list reads like the scheme of work it mirrors.
model SyllabusTopic {
  id        String   @id @default(cuid())
  schoolId  String
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  levelId   String
  level     Level    @relation(fields: [levelId], references: [id])
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  coverage SyllabusCoverage[]

  @@index([schoolId, subjectId, levelId])
}

/// A topic marked covered for one class. One row per (topic, class); unmarking deletes it —
/// coverage is a fact about teaching, not an audit ledger.
model SyllabusCoverage {
  id          String        @id @default(cuid())
  schoolId    String
  topicId     String
  topic       SyllabusTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  classId     String
  classRoom   ClassRoom     @relation(fields: [classId], references: [id])
  coveredById String
  coveredAt   DateTime      @default(now())

  @@unique([topicId, classId])
  @@index([schoolId, classId])
}

/// One mark per member of staff per day — the staff register (FEATURES.md §3/§17).
/// Reuses the student AttendanceStatus vocabulary; a User is the subject instead of a Student.
model StaffAttendanceRecord {
  id           String           @id @default(cuid())
  schoolId     String
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  date         DateTime
  status       AttendanceStatus
  recordedById String
  recordedAt   DateTime         @default(now())

  @@unique([schoolId, userId, date])
  @@index([schoolId, date])
}

enum LeaveStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

/// A member of staff asking for time away. Requests are decided by someone else — the service
/// refuses self-approval, because leave is the smallest version of separation of duties.
model LeaveRequest {
  id           String      @id @default(cuid())
  schoolId     String
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  /// ANNUAL | SICK | MATERNITY | CASUAL | STUDY | OTHER — free string, schools name their own.
  kind         String
  startDate    DateTime
  endDate      DateTime
  reason       String
  status       LeaveStatus @default(PENDING)
  decidedById  String?
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime    @default(now())

  @@index([schoolId, status])
  @@index([userId])
}

enum CarLineStatus {
  WAITING
  CALLED
  DONE
  CANCELLED
}

/// A guardian announcing from the car that they have arrived for pickup. The staff queue display
/// reads WAITING/CALLED rows in arrival order; dismissal wait-time analytics derive from
/// announcedAt → doneAt. Rows are never deleted — a cancelled arrival is still an arrival.
model CarLineEntry {
  id          String        @id @default(cuid())
  schoolId    String
  guardianId  String
  guardian    Guardian      @relation(fields: [guardianId], references: [id])
  announcedAt DateTime      @default(now())
  status      CarLineStatus @default(WAITING)
  calledAt    DateTime?
  doneAt      DateTime?

  @@index([schoolId, announcedAt])
  @@index([guardianId])
}

/// Immutable record of a child arriving in the morning — the other half of the gate's day.
/// Mirrors ReleaseLog: name captured at the time, idempotent via clientRef so the gate can
/// work offline without recording the same arrival twice.
model CheckInLog {
  id            String        @id @default(cuid())
  schoolId      String
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])
  /// Who brought the child, captured by name at the time; null when they arrived unaccompanied.
  broughtBy     String?
  collectorKind String?
  collectorId   String?
  method        ReleaseMethod @default(MANUAL)
  recordedById  String
  checkedInAt   DateTime      @default(now())
  /// Idempotency key minted by the gate device before it tries to send (see ReleaseLog.clientRef).
  clientRef     String?

  @@unique([schoolId, clientRef])
  @@index([schoolId, checkedInAt])
  @@index([studentId])
}

enum DismissalStatus {
  PENDING
  APPROVED
  DECLINED
}

/// A guardian telling the school, today, that the usual arrangement is changing.
model DismissalRequest {
  id          String          @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id])
  guardianId  String
  guardian    Guardian        @relation(fields: [guardianId], references: [id])
  forDate     DateTime
  details     String
  status      DismissalStatus @default(PENDING)
  decidedById String?
  decidedAt   DateTime?
  decisionNote String?
  createdAt   DateTime        @default(now())

  @@index([schoolId, forDate])
  @@index([studentId])
}

/// School-editable message bodies for automatic SMS. Placeholders in {braces} are substituted
/// at send time, so a school can reword a reminder without a deploy.
model MessageTemplate {
  id        String   @id @default(cuid())
  schoolId  String
  /// FEE_REMINDER_GENTLE, FEE_REMINDER_FIRM, ABSENCE_ALERT, RESULTS_READY, PICKUP_RELEASED
  kind      String
  body      String
  updatedAt DateTime @updatedAt

  @@unique([schoolId, kind])
}

/// A repeating automatic job a school has switched on (currently fee reminders). Kept in the
/// database rather than config so each school chooses its own day and hour.
model ScheduledJob {
  id         String    @id @default(cuid())
  schoolId   String
  kind       String
  enabled    Boolean   @default(false)
  /// 0-6, Sunday = 0. Null means every weekday.
  dayOfWeek  Int?
  hour       Int       @default(9)
  lastRunAt  DateTime?
  updatedAt  DateTime  @updatedAt

  @@unique([schoolId, kind])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2 — money, safety and reach
// ─────────────────────────────────────────────────────────────────────────────

/// One scheduled part-payment of an invoice.
///
/// The ledger stays the single source of what is owed; an installment is a *promise* about when
/// a slice of it falls due, never a second record of the money. Nothing here is summed to build
/// a balance — that always comes from LedgerEntry.
model Installment {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  termId    String?
  sequence  Int
  amount    Decimal  @db.Decimal(12, 2)
  dueDate   DateTime
  note      String?
  createdAt DateTime @default(now())

  @@unique([invoiceId, sequence])
  @@index([schoolId, dueDate])
  @@index([schoolId, studentId])
}

enum SettlementStatus {
  UNMATCHED
  MATCHED
  /// Matched but the amounts differ beyond tolerance — a human must look.
  DISPUTED
  /// The same reference appeared earlier in the file; counted once, kept so the bursar sees it.
  DUPLICATE
  IGNORED
}

/// A settlement file from a gateway: what they say they actually paid the school.
model SettlementBatch {
  id           String   @id @default(cuid())
  schoolId     String
  provider     GatewayProvider
  filename     String
  /// Gross the school expected, net the gateway actually remitted after charges.
  grossTotal   Decimal  @db.Decimal(12, 2)
  netTotal     Decimal  @db.Decimal(12, 2)
  rowCount     Int
  matchedCount Int      @default(0)
  uploadedById String?
  createdAt    DateTime @default(now())

  rows SettlementRow[]

  @@index([schoolId, createdAt])
}

/// One line of a settlement file, matched against a PaymentIntent by reference.
model SettlementRow {
  id         String           @id @default(cuid())
  schoolId   String
  batchId    String
  batch      SettlementBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  reference  String
  gross      Decimal          @db.Decimal(12, 2)
  /// What the gateway actually remitted; gross minus their charge.
  net        Decimal          @db.Decimal(12, 2)
  paidAt     DateTime?
  status     SettlementStatus @default(UNMATCHED)
  intentId   String?
  /// Why this row is disputed or was ignored — always a human sentence, never a code.
  note       String?
  resolvedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([schoolId, status])
  @@index([schoolId, reference])
}

enum ApplicantStage {
  ENQUIRY
  APPLIED
  ASSESSED
  OFFERED
  ACCEPTED
  ENROLLED
  DECLINED
}

/// A child applying to the school, before they are a Student.
///
/// Deliberately a separate table: an applicant has no class, no ledger and no attendance, and
/// letting them into Student early would corrupt enrolment counts and the fee cap.
model Applicant {
  id           String         @id @default(cuid())
  schoolId     String
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  gender       Gender?
  levelId      String?
  level        Level?         @relation(fields: [levelId], references: [id])
  guardianName String
  guardianPhone String
  guardianEmail String?
  previousSchool String?
  notes        String?
  stage        ApplicantStage @default(APPLIED)
  /// Set when the applicant becomes a Student, so the pipeline keeps an honest history.
  studentId    String?
  reference    String
  decidedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  documents ApplicantDocument[]

  @@unique([schoolId, reference])
  @@index([schoolId, stage])
}

enum CustomFieldKind {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  CHOICE
}

/// A school-defined extra field on a student record, optionally only for one level.
model CustomFieldDef {
  id        String          @id @default(cuid())
  schoolId  String
  label     String
  kind      CustomFieldKind @default(TEXT)
  /// CHOICE options; ignored for every other kind.
  options   Json?
  levelId   String?
  level     Level?          @relation(fields: [levelId], references: [id], onDelete: Cascade)
  required  Boolean         @default(false)
  order     Int             @default(0)
  createdAt DateTime        @default(now())

  values StudentFieldValue[]

  @@index([schoolId, levelId])
}

model StudentFieldValue {
  id        String         @id @default(cuid())
  schoolId  String
  studentId String
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fieldId   String
  field     CustomFieldDef @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value     String
  updatedAt DateTime       @updatedAt

  @@unique([studentId, fieldId])
  @@index([schoolId])
}

/// A document every child at a level is expected to have on file.
model DocumentRequirement {
  id        String   @id @default(cuid())
  schoolId  String
  label     String
  /// Matches StudentDocument.kind, which is how completion is worked out.
  kind      String
  levelId   String?
  level     Level?   @relation(fields: [levelId], references: [id], onDelete: Cascade)
  required  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([schoolId, levelId])
}

enum RemarkKind {
  TEACHER
  HEAD
  CONDUCT
  INTEREST
}

/// A reusable report-card comment, so a class teacher writing 40 reports is not starting cold.
model RemarkBank {
  id        String     @id @default(cuid())
  schoolId  String
  kind      RemarkKind
  text      String
  /// Roughly which band this suits, so the editor can offer sensible ones first. Null = any.
  minScore  Int?
  maxScore  Int?
  uses      Int        @default(0)
  createdAt DateTime   @default(now())

  @@index([schoolId, kind])
}

enum EventAudience {
  ALL
  STAFF
  GUARDIANS
  STUDENTS
}

model CalendarEvent {
  id          String        @id @default(cuid())
  schoolId    String
  title       String
  details     String?
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean       @default(true)
  location    String?
  audience    EventAudience @default(ALL)
  levelId     String?
  level       Level?        @relation(fields: [levelId], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([schoolId, startsAt])
}

/// A file a teacher shares with a class: notes, homework, past questions.
model LearningResource {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  description String?
  /// Storage key. Bytes are served through the API, never a public URL.
  key         String
  filename    String
  mimeType    String
  sizeBytes   Int
  subjectId   String?
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  levelId     String?
  level       Level?   @relation(fields: [levelId], references: [id], onDelete: SetNull)
  classId     String?
  classRoom   ClassRoom? @relation(fields: [classId], references: [id], onDelete: SetNull)
  /// Guardians and students only see it once the teacher publishes.
  published   Boolean  @default(false)
  uploadedById String?
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([schoolId, levelId])
  @@index([schoolId, classId])

  downloadLog ResourceDownload[]
}

/// Who opened a resource — the catalog asks for download tracking.
model ResourceDownload {
  id         String   @id @default(cuid())
  schoolId   String
  resourceId String
  resource   LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  /// Exactly one of these is set, depending on which portal did the download.
  userId     String?
  guardianId String?
  studentId  String?
  createdAt  DateTime @default(now())

  @@index([schoolId, resourceId])
}

/// A named slot in the school day — "Period 1", "Break". Shared by every class.
model TimetablePeriod {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  /// Minutes from midnight, so comparisons and clash detection are plain integer maths.
  startsMin Int
  endsMin   Int
  order     Int      @default(0)
  isBreak   Boolean  @default(false)
  createdAt DateTime @default(now())

  slots TimetableSlot[]

  @@index([schoolId, order])
}

/// One class, one period, one weekday: what is being taught and by whom.
model TimetableSlot {
  id        String          @id @default(cuid())
  schoolId  String
  classId   String
  classRoom ClassRoom       @relation(fields: [classId], references: [id], onDelete: Cascade)
  periodId  String
  period    TimetablePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  /// 1 = Monday … 5 = Friday. Ghanaian schools rarely timetable weekends.
  weekday   Int
  subjectId String?
  subject   Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacherId String?
  teacher   User?           @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  room      String?
  createdAt DateTime        @default(now())

  /// A class cannot be in two places in one period. Teacher clashes are checked in code,
  /// because they span classes and a unique index cannot express "unless the teacher is null".
  @@unique([classId, periodId, weekday])
  @@index([schoolId, teacherId, weekday])

  substitutions Substitution[]
}

/// Cover for one lesson on one date (FEATURES.md §6). A null relief teacher records the honest
/// outcome — the lesson goes unstaffed — rather than pretending someone was found.
model Substitution {
  id              String        @id @default(cuid())
  schoolId        String
  slotId          String
  slot            TimetableSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  /// The calendar day being covered; the slot's weekday must match it.
  date            DateTime
  reliefTeacherId String?
  reliefTeacher   User?         @relation("ReliefCover", fields: [reliefTeacherId], references: [id], onDelete: SetNull)
  reason          String?
  createdById     String
  createdAt       DateTime      @default(now())

  @@unique([schoolId, slotId, date])
  @@index([schoolId, date])
}

enum WhatsAppDirection {
  INBOUND
  OUTBOUND
}

/// A WhatsApp thread with one phone number.
///
/// The school never opens one. `windowExpiresAt` is set only by an inbound message and is the
/// gate on every reply: outside it we cannot answer without a paid template, and this product
/// has decided not to send those. See WhatsAppMessage.
model WhatsAppConversation {
  id              String    @id @default(cuid())
  schoolId        String
  phone           String
  guardianId      String?
  guardian        Guardian? @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  /// 24 hours after the guardian's last inbound message. Null or past = we must stay silent.
  windowExpiresAt DateTime?
  lastInboundAt   DateTime?
  lastOutboundAt  DateTime?
  /// The assistant's little memory: `{ pending?: intent, handedOff?: true }`. `handedOff`
  /// silences the bot for the rest of the window — a person asked for a person.
  botState        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  messages WhatsAppMessage[]

  @@unique([schoolId, phone])
  @@index([schoolId, windowExpiresAt])
}

model WhatsAppMessage {
  id             String               @id @default(cuid())
  schoolId       String
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      WhatsAppDirection
  body           String
  /// Provider's own id, used to make webhook redelivery idempotent.
  externalId     String?
  sentById       String?
  createdAt      DateTime             @default(now())

  @@unique([schoolId, externalId])
  @@index([schoolId, conversationId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Concession rules — scholarships, bursaries, staff-child and sibling discounts
//
// A rule is a *policy*, not money. It decides how much DISCOUNT to append to the ledger when a
// term is invoiced; the ledger remains the only record of what is owed. Nothing here is ever
// summed to produce a balance.
// ─────────────────────────────────────────────────────────────────────────────

enum ConcessionKind {
  /// Awarded to named students — merit, bursary, staff child.
  SCHOLARSHIP
  /// Applied automatically to families with more than one child on the roll.
  SIBLING
}

enum ConcessionBasis {
  PERCENT
  AMOUNT
}

model ConcessionRule {
  id       String          @id @default(cuid())
  schoolId String
  name     String
  kind     ConcessionKind
  basis    ConcessionBasis
  /// A percentage (0–100) or a flat amount in the school's currency, per `basis`.
  value    Decimal         @db.Decimal(12, 2)
  /// SIBLING only: the child this starts applying from, counting eldest first. 2 = "second
  /// child onward", which is how schools actually describe it.
  fromSibling Int?
  /// Restrict to one level; null applies school-wide.
  levelId  String?
  level    Level?          @relation(fields: [levelId], references: [id], onDelete: Cascade)
  active   Boolean         @default(true)
  /// Optional window. A scholarship awarded for one year should not quietly run forever.
  startsOn DateTime?
  endsOn   DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  awards ConcessionAward[]

  /// Rules stack, so two rules with the same name would silently double a discount. A school
  /// wanting two genuinely different scholarships names them differently.
  @@unique([schoolId, name])
  @@index([schoolId, active])
}

/// A named student holding a SCHOLARSHIP rule. Sibling rules need no award — they are worked
/// out from the family each time invoices are raised.
model ConcessionAward {
  id        String         @id @default(cuid())
  schoolId  String
  ruleId    String
  rule      ConcessionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  studentId String
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  /// Why this child — a scholarship without a stated reason is a favour, not a policy.
  reason    String
  awardedById String?
  createdAt DateTime       @default(now())

  @@unique([ruleId, studentId])
  @@index([schoolId, studentId])
}

/// The licence installed on this box.
///
/// At most one row, because there is at most one deployment — this is a property of the server,
/// not of the school on it, which is why it carries no schoolId. Row-level security is enabled
/// with no policy at all, so the app role cannot read it: every access goes through
/// LicenceService on the owner connection, the same shape as any other deployment-level secret.
///
/// The raw text is the source of truth. The parsed columns beside it exist so the settings screen
/// and the boot log can say something useful without re-verifying a signature on every read.
model Licence {
  /// Always "singleton". A fixed id makes install an upsert and makes a second row impossible.
  id            String   @id @default("singleton")
  /// The licence exactly as the vendor issued it, re-verified hourly and on boot.
  raw           String
  licenceId     String
  schoolSlug    String
  tier          Tier
  expiresAt     DateTime
  issuedAt      DateTime
  /// When this box last reported to its supplier, and whether that report landed.
  ///
  /// Persisted so the licence screen can show a school exactly when its server last spoke to the
  /// vendor. A product sold partly on not phoning home has to be able to answer that question
  /// truthfully, and "trust us" is not an answer.
  lastHeartbeatAt DateTime?
  lastHeartbeatOk Boolean?

  installedAt   DateTime @default(now())
  /// Null when the licence came from LICENCE_FILE or LICENCE rather than the settings screen.
  installedById String?
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Broadcasts — one message, several channels
//
// Announcements and bulk SMS were two unrelated features with two different ideas of "audience":
// SMS meant ALL/CLASS/LEVEL/CUSTOM (which people) and an announcement meant ALL/GUARDIANS/STUDENTS
// (which portals). Those are orthogonal axes that got conflated, so they are separated here and a
// Broadcast carries both.
//
// A Broadcast does not replace what it produces. It EMITS an Announcement for the portals,
// SmsMessage rows for texts (which debit credits and feed the messaging log), BroadcastDelivery
// rows for email, and SocialPost rows for social. Collapsing those into one delivery table would
// have broken the SMS credit ledger and the four automated senders that write SmsMessage directly.
// ─────────────────────────────────────────────────────────────────────────────

model Broadcast {
  id       String @id @default(cuid())
  schoolId String
  title    String
  body     String

  /// WHICH PEOPLE — the SMS vocabulary. ALL | CLASS | LEVEL | ROUTE | CUSTOM
  audienceScope String   @default("ALL")
  classId       String?
  levelId       String?
  /// For ROUTE scope: the transport route whose riders' families are addressed.
  routeId       String?
  /// Explicit numbers, for CUSTOM.
  recipients    String[]
  /// WHICH PORTALS — the Announcement vocabulary. GUARDIANS | STUDENTS | STAFF
  audienceRoles String[] @default(["GUARDIANS"])
  /// PORTAL | SMS | EMAIL | SOCIAL
  channels      String[]

  /// DRAFT | QUEUED | SENDING | SENT | PARTIAL | FAILED
  status String @default("QUEUED")

  /// Client-generated, so a double-submit is one broadcast.
  ///
  /// SmsMessage.batchId is `SMS-${Date.now()}` minted server-side, which cannot dedupe anything —
  /// two clicks produce two batch ids and two sends. A key the client generates once per compose
  /// is the only thing that closes that.
  idempotencyKey String

  createdById String
  createdAt   DateTime  @default(now())
  sentAt      DateTime?

  media      BroadcastMedia[]
  deliveries BroadcastDelivery[]
  posts      SocialPost[]

  @@unique([schoolId, idempotencyKey])
  @@index([schoolId, createdAt])
}

/// An image attached to a broadcast. Field set mirrors LearningResource deliberately.
model BroadcastMedia {
  id          String    @id @default(cuid())
  schoolId    String
  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  key       String
  filename  String
  mimeType  String
  sizeBytes Int
  order     Int    @default(0)

  /// Minted immediately before an Instagram publish and revoked straight after.
  ///
  /// Instagram accepts only a publicly fetchable image_url — there is no binary upload — so this
  /// is the one place the no-public-URLs rule in common/storage.ts has to bend. It bends narrowly:
  /// one route, a fifteen-minute life, cleared in the same transaction as the publish response,
  /// and for a marketing image that is seconds away from being on a public Instagram account.
  publicToken          String?   @unique
  publicTokenExpiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([schoolId, broadcastId])
}

/// One row per email recipient. SMS keeps SmsMessage; social keeps SocialPost.
model BroadcastDelivery {
  id          String    @id @default(cuid())
  schoolId    String
  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  channel     String
  target      String
  /// QUEUED | SENT | FAILED
  status      String    @default("QUEUED")
  providerRef String?
  error       String?
  createdAt   DateTime  @default(now())
  sentAt      DateTime?

  /// Retrying a broadcast must not send the same person the same thing twice.
  @@unique([schoolId, broadcastId, channel, target])
  @@index([schoolId, broadcastId])
}

enum SocialPlatform {
  FACEBOOK_PAGE
  INSTAGRAM
  X
  TIKTOK
}

/// A school's own social account, connected by the school.
///
/// Modelled on GatewayAccount: composite unique, the credential encrypted at rest, and a list
/// endpoint that returns whether a token exists rather than the token.
model SocialAccount {
  id       String         @id @default(cuid())
  schoolId String
  platform SocialPlatform

  /// Page id, Instagram user id, or handle.
  externalId  String
  displayName String

  accessTokenEnc  String
  refreshTokenEnc String?
  /// From the platform's own answer (Meta's debug_token), never from what the user typed.
  tokenExpiresAt  DateTime?
  scopes          String[]

  /// ACTIVE | EXPIRING | EXPIRED | REVOKED
  status    String  @default("ACTIVE")
  active    Boolean @default(true)

  connectedById String?
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  posts SocialPost[]

  @@unique([schoolId, platform, externalId])
  @@index([schoolId, status])
}

/// One attempt to put one broadcast on one account.
model SocialPost {
  id          String    @id @default(cuid())
  schoolId    String
  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  accountId   String
  account     SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform    SocialPlatform

  /// QUEUED | PUBLISHED | FAILED | SKIPPED
  status      String    @default("QUEUED")
  /// The platform's own post id — the WhatsAppMessage idempotency pattern.
  externalId  String?
  permalink   String?
  error       String?
  attempts    Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([schoolId, platform, externalId])
  /// Enqueueing the same broadcast twice must not post twice.
  @@unique([broadcastId, accountId])
  @@index([schoolId, status])
}

/// Which sign-in page a photograph belongs to.
///
/// One per door, so a school can show guardians its gate at closing time and staff its office,
/// rather than one picture doing for everybody. GENERAL covers the pages nobody arrives at on
/// purpose — password reset, first-run setup — where a neutral image is right.
enum BrandPhotoSlot {
  STAFF
  FAMILY
  STUDENT
  GENERAL
}

/// A photograph the school chose for one of its sign-in pages.
///
/// The product ships CC0 defaults (apps/web/public/photos) so a fresh install looks finished, but
/// those are stock pictures of somebody else's school. Anything here overrides them, and a school
/// removing its upload falls back to the default rather than to an empty panel.
///
/// Served unauthenticated by GET /public/branding/photo/:slot, alongside the crest and for the
/// same reason: a sign-in page has to render before anyone has a session. See the carve-out note
/// in common/storage.ts — this is institutional imagery the school chose to show the public, not
/// anything about a child.
model BrandPhoto {
  id       String         @id @default(cuid())
  schoolId String
  slot     BrandPhotoSlot

  key       String
  filename  String
  mimeType  String
  sizeBytes Int

  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([schoolId, slot])
}
