// EYO SMS — core schema (Phase 1: SIS, attendance, assessment, fees)
// Rules: every tenant-owned table carries schoolId; the fee ledger is append-only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenancy, users, platform ─────────────────────────────────────────

enum Tier {
  BASIC
  MEDIUM
  ADVANCED
}

/// Terminal-report layout. GES is the statutory-looking default; MODERN is a cleaner
/// alternative some private schools prefer (docs/02 §2.3).
enum ReportTemplate {
  GES
  MODERN
}

enum Role {
  OWNER
  HEAD
  BURSAR
  TEACHER
  FRONT_DESK
  GUARDIAN
}

model School {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  motto     String?
  address   String?
  phone     String?
  email     String?
  region    String?
  country   String   @default("GH")
  currency  String   @default("GHS")
  tier      Tier     @default(BASIC)
  logoUrl   String?
  smsSenderId String? // registered SMS sender ID (e.g. "BRIGHTON")
  smsCredits  Int      @default(0) // pay-as-you-go SMS units the school has bought
  reportTemplate ReportTemplate @default(GES)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  academicYears AcademicYear[]
  levels        Level[]
  classes       ClassRoom[]
  subjects      Subject[]
  students      Student[]
  guardians     Guardian[]
}

model User {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId])
}

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  detail    Json?
  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
}

// ── Academic structure ───────────────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  terms     Term[]

  @@unique([schoolId, name])
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  name           String
  startDate      DateTime
  endDate        DateTime
  nextTermBegins DateTime?
  isCurrent      Boolean      @default(false)

  @@unique([academicYearId, name])
}

enum LevelCategory {
  PRE_SCHOOL
  PRIMARY
  JHS
  SHS
}

model Level {
  id              String         @id @default(cuid())
  schoolId        String
  school          School         @relation(fields: [schoolId], references: [id])
  name            String
  category        LevelCategory
  order           Int
  gradingSchemeId String? // which grading scheme this level's reports use (per-level selection)
  gradingScheme   GradingScheme? @relation(fields: [gradingSchemeId], references: [id])
  classes         ClassRoom[]

  @@unique([schoolId, name])
}

model ClassRoom {
  id            String    @id @default(cuid())
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id])
  levelId       String
  level         Level     @relation(fields: [levelId], references: [id])
  name          String
  classTeacherId String?
  students      Student[]

  @@unique([schoolId, name])
}

model Subject {
  id       String  @id @default(cuid())
  schoolId String
  school   School  @relation(fields: [schoolId], references: [id])
  name     String
  code     String
  isCore   Boolean @default(false)

  @@unique([schoolId, code])
}

// ── Students & guardians ─────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  TRANSFERRED
  WITHDRAWN
  GRADUATED
}

enum Gender {
  MALE
  FEMALE
}

model Student {
  id           String        @id @default(cuid())
  schoolId     String
  school       School        @relation(fields: [schoolId], references: [id])
  admissionNo  String
  firstName    String
  lastName     String
  otherNames   String?
  gender       Gender
  dateOfBirth  DateTime
  photoUrl     String?
  classId      String?
  classRoom    ClassRoom?    @relation(fields: [classId], references: [id])
  status       StudentStatus @default(ACTIVE)
  enrolledAt   DateTime      @default(now())
  exitDate     DateTime? // set on transfer / withdrawal / graduation
  exitReason   String?
  medicalNotes String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  guardians    StudentGuardian[]
  attendance   AttendanceRecord[]
  scores       Score[]
  termReports  TermReport[]
  invoices     Invoice[]
  ledger       LedgerEntry[]
  documents      StudentDocument[]
  bankDeposits   BankDeposit[]
  paymentIntents PaymentIntent[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId, classId])
}

/// Files attached to a student (birth certificate, immunisation card, previous report…).
/// `key` addresses the object in storage; bytes are never stored in the database.
model StudentDocument {
  id           String   @id @default(cuid())
  schoolId     String
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  kind         String   @default("OTHER")
  filename     String
  contentType  String
  size         Int
  key          String
  uploadedById String
  createdAt    DateTime @default(now())

  @@index([schoolId, studentId])
}

enum DepositStatus {
  PENDING
  CONFIRMED
  REJECTED
}

/// A bank deposit claimed by a guardian/office with proof attached. Nothing reaches the
/// ledger until a bursar confirms it — confirmation appends a PAYMENT entry + receipt.
model BankDeposit {
  id            String        @id @default(cuid())
  schoolId      String
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id])
  termId        String?
  amount        Decimal       @db.Decimal(12, 2)
  bankName      String?
  bankRef       String?
  depositedAt   DateTime
  proofKey      String?
  status        DepositStatus @default(PENDING)
  /// Reference of the ledger entry created on confirmation — also the idempotency key.
  reference     String        @unique
  note          String?
  reviewNote    String?
  submittedById String
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())

  @@index([schoolId, status])
}

enum CustodyFlag {
  NONE
  RESTRICTED
  BLOCKED
}

model Guardian {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  firstName     String
  lastName      String
  phone         String
  email         String?
  whatsappOptIn Boolean  @default(false)
  createdAt     DateTime @default(now())

  students StudentGuardian[]
  otps     GuardianOtp[]

  @@index([schoolId, phone])
}

/// One-time sign-in codes for the guardian portal. Only a hash of the code is stored, so a
/// database leak cannot be replayed into guardian accounts.
model GuardianOtp {
  id         String    @id @default(cuid())
  schoolId   String
  guardianId String
  guardian   Guardian  @relation(fields: [guardianId], references: [id])
  phone      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([guardianId])
}

model StudentGuardian {
  studentId    String
  student      Student     @relation(fields: [studentId], references: [id])
  guardianId   String
  guardian     Guardian    @relation(fields: [guardianId], references: [id])
  relationship String
  isPrimary    Boolean     @default(false)
  canPickup    Boolean     @default(true)
  custodyFlag  CustodyFlag @default(NONE)

  @@id([studentId, guardianId])
}

// ── Attendance ───────────────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  schoolId   String
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id])
  classId    String
  termId     String
  date       DateTime         @db.Date
  status     AttendanceStatus
  markedById String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, date])
  @@index([schoolId, classId, date])
}

// ── Assessment & terminal reports ────────────────────────────────────

enum GradingKind {
  GES_CLASSIC
  NACCA_BANDS
  EARLY_YEARS
}

model GradingScheme {
  id       String      @id @default(cuid())
  schoolId String
  name     String
  kind     GradingKind
  /// bands: [{ min, max, grade, remark }] — for NaCCA/early-years, `grade` carries the proficiency label
  bands    Json
  levels   Level[]

  @@unique([schoolId, name])
}

model AssessmentComponent {
  id       String  @id @default(cuid())
  schoolId String
  name     String
  maxScore Int
  isExam   Boolean @default(false)
  order    Int     @default(0)

  scores Score[]

  @@unique([schoolId, name])
}

model Score {
  id          String              @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student             @relation(fields: [studentId], references: [id])
  subjectId   String
  termId      String
  componentId String
  component   AssessmentComponent @relation(fields: [componentId], references: [id])
  rawScore    Float
  enteredById String
  updatedAt   DateTime            @updatedAt

  @@unique([studentId, subjectId, termId, componentId])
  @@index([schoolId, termId, subjectId])
}

model TermReport {
  id                String    @id @default(cuid())
  schoolId          String
  studentId         String
  student           Student   @relation(fields: [studentId], references: [id])
  termId            String
  classId           String
  /// lines: [{ subject, sba30, exam70, total, grade, remark, position }]
  lines             Json
  overallTotal      Float
  classPosition     Int?
  classSize         Int?
  attendancePresent Int       @default(0)
  attendanceTotal   Int       @default(0)
  conduct           String?
  interest          String?
  teacherRemark     String?
  headRemark        String?
  publishedAt       DateTime?
  generatedAt       DateTime  @default(now())

  @@unique([studentId, termId])
  @@index([schoolId, termId, classId])
}

// ── Fees: append-only ledger ─────────────────────────────────────────

model FeeItem {
  id       String  @id @default(cuid())
  schoolId String
  termId   String
  levelId  String?
  name     String
  amount   Decimal @db.Decimal(12, 2)
  optional Boolean @default(false)

  @@index([schoolId, termId])
}

model Invoice {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  termId    String
  number    String
  /// lines: [{ name, amount }]
  lines     Json
  total     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  paymentIntents PaymentIntent[]

  @@unique([schoolId, number])
  @@unique([studentId, termId])
  @@index([schoolId, termId])
}

enum LedgerType {
  INVOICE
  PAYMENT
  DISCOUNT
  WAIVER
  REVERSAL
}

enum PaymentMethod {
  CASH
  BANK
  MOMO
  CARD
}

/// Append-only. Never updated, never deleted. Corrections are REVERSAL entries.
model LedgerEntry {
  id          String         @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student        @relation(fields: [studentId], references: [id])
  termId      String?
  type        LedgerType
  /// Positive amounts. INVOICE increases balance owed; PAYMENT/DISCOUNT/WAIVER decrease it;
  /// REVERSAL negates the entry it references (reversedId).
  amount      Decimal        @db.Decimal(12, 2)
  method      PaymentMethod?
  reference   String         @unique
  reversedId  String?
  note        String?
  createdById String
  createdAt   DateTime       @default(now())

  receipt Receipt?

  @@index([schoolId, studentId])
  @@index([schoolId, createdAt])
}

model Receipt {
  id            String      @id @default(cuid())
  schoolId      String
  ledgerEntryId String      @unique
  ledgerEntry   LedgerEntry @relation(fields: [ledgerEntryId], references: [id])
  number        String
  issuedAt      DateTime    @default(now())

  @@unique([schoolId, number])
}

// ── Online payments (Medium: fees.online) ────────────────────────────

enum GatewayProvider {
  HUBTEL
  PAYSTACK
  MOCK
}

enum GatewayMode {
  TEST
  LIVE
}

enum PaymentChannel {
  MOMO
  CARD
  USSD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

/// Per-school merchant credentials. `secretEnc` is AES-256-GCM ciphertext (common/crypto.ts);
/// plaintext secrets are never stored or returned by the API.
model GatewayAccount {
  id             String          @id @default(cuid())
  schoolId       String
  provider       GatewayProvider
  mode           GatewayMode     @default(TEST)
  publicKey      String?
  secretEnc      String
  merchantNumber String? // Hubtel merchant account number
  subaccountCode String? // Paystack subaccount, if split settlement is used
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([schoolId, provider])
}

/// One attempt to collect money. Only a SUCCESS ever writes to the ledger, and it does so
/// with `reference` — LedgerEntry.reference is unique, which makes application idempotent.
model PaymentIntent {
  id          String          @id @default(cuid())
  schoolId    String
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id])
  invoiceId   String?
  invoice     Invoice?        @relation(fields: [invoiceId], references: [id])
  termId      String?
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @default("GHS")
  reference   String          @unique
  provider    GatewayProvider
  channel     PaymentChannel
  status      PaymentStatus   @default(PENDING)
  providerRef String?
  checkoutUrl String?
  /// Opaque token for the public (unauthenticated) pay link shared with guardians.
  payToken    String?         @unique
  payerPhone  String?
  failureCode String?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([schoolId, status])
  @@index([schoolId, createdAt])
}

/// Raw gateway callbacks. `providerEventId` is unique so a replayed webhook is a no-op.
model WebhookEvent {
  id              String          @id @default(cuid())
  provider        GatewayProvider
  providerEventId String
  schoolId        String?
  reference       String?
  verified        Boolean         @default(false)
  payload         Json
  error           String?
  receivedAt      DateTime        @default(now())
  processedAt     DateTime?

  @@unique([provider, providerEventId])
  @@index([reference])
}

// ── Communication ────────────────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  schoolId    String
  title       String
  body        String
  audience    String    @default("ALL")
  createdById String
  publishedAt DateTime  @default(now())

  @@index([schoolId, publishedAt])
}

enum SmsStatus {
  QUEUED
  SENT
  FAILED
}

/// Outbound bulk-SMS log. One row per recipient; `cost` debits School.smsCredits.
model SmsMessage {
  id          String    @id @default(cuid())
  schoolId    String
  to          String
  body        String
  status      SmsStatus @default(QUEUED)
  provider    String    @default("mock")
  providerRef String?
  cost        Int       @default(1)
  batchId     String?
  error       String?
  createdById String
  createdAt   DateTime  @default(now())

  @@index([schoolId, createdAt])
  @@index([schoolId, batchId])
}
