# Klasio pre-live — the box's own secrets. Copy to /opt/klasio/.env ON THE SERVER and fill in.
# Never commit the filled-in copy; the deploy workflow explicitly rsyncs .env* out of the way so
# a checkout can never overwrite it.
#
# Generate every secret below on the box:
#   openssl rand -hex 32

# --- Domains and TLS ---------------------------------------------------------
# All three need an A record pointing at this server BEFORE the first deploy, or Caddy fails the
# ACME challenge and backs off.
WEB_DOMAIN=klasio.example.com
API_DOMAIN=api.klasio.example.com
VENDOR_DOMAIN=licensing.klasio.example.com
ACME_EMAIL=cloud.aaodoom@gmail.com

# Comma-separated CIDRs allowed to reach the vendor portal, e.g. "41.x.x.x/32 102.x.x.x/32".
# Set this AND uncomment the matching block in the Caddyfile. Left empty the portal is open to
# the internet, which for a licence-signing service is a decision, not a default.
VENDOR_ALLOWED_IPS=

# --- School database ---------------------------------------------------------
DB_PASSWORD=
# The password the init script creates the non-owner eyo_app role with. The API connects as that
# role, which is what makes row-level security apply at all.
APP_DB_PASSWORD=

# --- School app --------------------------------------------------------------
# Signs every school session. The API refuses to start without it.
JWT_SECRET=
# Encrypts per-school secrets at rest (gateway credentials, social tokens). 32 bytes hex/base64.
# Changing this later cannot decrypt what the old one stored.
APP_ENCRYPTION_KEY=
# The PUBLIC half of the vendor signing pair, as an SPKI PEM or base64. Without it the box
# refuses every licence and runs on the free package.
LICENCE_PUBLIC_KEY=
# Optional telemetry. Points at the vendor portal on this same box.
LICENCE_HEARTBEAT_URL=

# --- Vendor portal -----------------------------------------------------------
VENDOR_DB_PASSWORD=
VENDOR_SESSION_SECRET=
VENDOR_ENCRYPTION_KEY=
VENDOR_ADMIN_EMAIL=
VENDOR_ADMIN_NAME=Klasio Admin
# NOTE: the signing key itself is NOT set here. It is a file at
# /opt/klasio/vendor-keys/signing-key.pem, mounted read-only into the container. See the README.

# --- Messaging ---------------------------------------------------------------
# Shared with kito-ride today; the Nalo sender ID still reads Kito.
NALO_SMS_ENDPOINT=https://sms.nalosolutions.com/smsbackend/clientapi/Resl_Nalo/send-message/
NALO_SMS_USERNAME=
NALO_SMS_PASSWORD=
NALO_SMS_SOURCE=
MAILERSEND_API_TOKEN=
MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME=Klasio

# Pre-live is still a real deployment: a mock records a message as SENT and delivers nothing, and
# a mock payment tells a parent they paid when nothing was charged. Turn one on only deliberately.
ALLOW_MOCK_SMS=false
ALLOW_MOCK_EMAIL=false
ALLOW_MOCK_PAYMENTS=false
